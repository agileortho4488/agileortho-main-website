{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:8001/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/catalog/products/[slug]",
      "regex": "^/catalog/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/catalog/products/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/catalog/[division]",
      "regex": "^/catalog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPdivision": "nxtPdivision"
      },
      "namedRegex": "^/catalog/(?<nxtPdivision>[^/]+?)(?:/)?$"
    },
    {
      "page": "/districts/[slug]",
      "regex": "^/districts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/districts/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/solutions/[procedure]",
      "regex": "^/solutions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprocedure": "nxtPprocedure"
      },
      "namedRegex": "^/solutions/(?<nxtPprocedure>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/catalog",
      "regex": "^/catalog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/catalog(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/districts",
      "regex": "^/districts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/districts(?:/)?$"
    },
    {
      "page": "/districts/%5Bslug%5D",
      "regex": "^/districts/%5Bslug%5D(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/districts/%5Bslug%5D(?:/)?$"
    },
    {
      "page": "/evidence",
      "regex": "^/evidence(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/evidence(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}