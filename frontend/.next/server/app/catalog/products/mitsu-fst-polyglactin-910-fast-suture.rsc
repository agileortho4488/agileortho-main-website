,"shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.702373+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Fast-Absorbing Synthetic Braided Suture","proposed_clinical_display_title":"MITSU FST Polyglactin 910 Fast Suture","proposed_clinical_subtitle":"Fast-Absorbing Synthetic Braided Suture","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:32:31.901026+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence provides coherent technical specifications for a fast-absorbing polyglactin 910 suture (50% tensile strength retention at 5 days, complete absorption 40-42 days, braided multifilament structure). This matches the clinical profile of rapid-absorption synthetic sutures used for short-term soft tissue approximation. However, MITSU FST appears to be a Meril Life Sciences proprietary brand designation that cannot be verified externally. The technical specifications are consistent with fast-absorbing polyglactin formulations (similar to Vicryl Rapide but with distinct absorption profile). No external sources available to confirm MITSU FST brand existence or validate exact specifications. Recommend review to: (1) confirm MITSU FST is legitimate Meril brand name, (2) verify technical specifications against manufacturer documentation, (3) clarify coating status (calcium stearate typically used but not mentioned), and (4) confirm intended use scope beyond general soft tissue.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["General Soft Tissue"],"proposed_semantic_brand_system":"MITSU FST","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Fast-Absorbing Synthetic Sutures","proposed_semantic_implant_class":"Absorbable Suture","proposed_semanti