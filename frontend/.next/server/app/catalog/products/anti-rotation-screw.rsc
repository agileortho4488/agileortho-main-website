78000","clinical_subtitle":"Locking Bolts for Intramedullary Nailing System","proposed_clinical_display_title":"ARMAR Anti-Rotation Screw","proposed_clinical_subtitle":"Locking Bolts for Intramedullary Nailing System","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:32:25.517783+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"Internal evidence clearly identifies this as locking bolts for intramedullary nailing, not standalone anti-rotation screws. The brochure description 'Locking bolts for intramedullary nailing system' is definitive. All SKU examples are labeled 'Locking Bolts (Nailing System)'. External source_1 confirms 4.9mm locking bolt specification within CLAVO system context. The product_id and current_title 'Anti-Rotation Screw' is misleading—these are locking bolts that serve anti-rotation function within the ARMAR/CLAVO intramedullary nail system. Entity type is 'instrument' as these are ancillary fixation components, not primary implants. Material Ti-6Al-7Nb confirmed. Recommend renaming to reflect true function: 'ARMAR Locking Bolts' with subtitle already accurately stating purpose. No conflict between sources; internal evidence is authoritative and externally supported.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Long Bones"],"proposed_semantic_brand_system":"ARMAR Anti-Rotation Screw","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Trauma Fixation Components","proposed_semantic_implant_class":"Locking Bolt","proposed_semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","proposed_semantic_parent_brand":"CLAVO Intramedullary Nailing System","proposed_semantic_procedure_scope":["Intramedullary Nailing","Fracture Fixation"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Intramedullary Nailing System","proposed_semantic_use_case_tags":["Locking Screw","Anti-Rotation","Intramedullary Nail Fixation","Self-Tapping"],"proposed_web_verification_status":"externally_enriched","semantic_anatomy_scope":["Long Bones"],"semantic_brand_system":"ARMAR Anti-Rotation Screw","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.511885+00:00","semantic_implant_class":"Locking Bolt","semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","semantic_parent_brand":"CLAVO Intramedullary Nailing System","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_ENRICHED"],"semantic_system_type":"Intramedullary Nailing System"}}]]}]]}],false,"$undefined","$L15","$L16"]}]]}]
