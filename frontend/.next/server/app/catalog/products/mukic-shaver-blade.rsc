eo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"family_brand_division","match_score":1,"catalog_created_at":"2026-03-27T16:50:59.624926+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"ENT Microdebrider Blade System for Endoscopic Sinus and Airway Surgery","proposed_clinical_display_title":"MUKIC Powered Shaver Blades","proposed_clinical_subtitle":"ENT Microdebrider Blade System for Endoscopic Sinus and Airway Surgery","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:06:52.852610+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly identifies this as a family of powered shaver blades (microdebrider blades) for ENT procedures. The brochure description provides comprehensive procedural scope (adenoidectomy, turbinoplasty, polypectomy, FESS, laryngeal, septoplasty) and specifies multiple angle options including exclusive 40-degree up/down designs. SKU examples (MUKB040dn, MUKB040up) confirm angle-specific variants. Current classification correctly identifies material and application but undersells the product as generic 'Shaver Blade'. Clinical terminology: these are powered microdebrider blades used with handpiece systems for controlled tissue removal in endoscopic ENT surgery. External sources confirm Meril's ENT product portfolio but do not provide blade-specific detail. Recommendation: rename to 'MUKIC Powered Shaver Blades' with subtitle clarifying microdebrider system and endoscopic application. High confidence based on internal brochure evidence alone.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Nasal Cavity","Paranasal Sinus