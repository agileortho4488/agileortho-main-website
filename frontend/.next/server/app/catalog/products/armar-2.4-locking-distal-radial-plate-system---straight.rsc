1a:["$","$L1e",null,{"product":{"product_name":"ARMAR 2.4 Locking Distal Radial Plate System - Straight","product_name_display":"2.4 Locking Distal Radial Plate System - Straight","sku_code":"MRL-ARM-002","product_family":"ARMAR 2.4 Locking Distal Radial Plate System - Straight","product_family_display":"ARMAR 2.4 Locking Distal Radial Plate System - Straight","slug":"armar-2.4-locking-distal-radial-plate-system---straight","images":[{"id":"prop_69c2d2d","storage_path":"agile-ortho/products/69c2d2d07171238d2edca5ad/cover_93e430f9.jpg","original_filename":"cover_LBL_Plate_Chart_Meril.pdf.jpg","content_type":"image/jpeg","size":572912,"uploaded_at":"2026-03-26T05:56:24.795886+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"2.4 Locking Distal Radial Plate System - Straight | Meril Distal Radial Plates - MedDevice Pro Telangana","seo_meta_description":"The ARMAR™ Orthopedic Trauma System provides a comprehensive range of titanium locking plates, screws, and specialized instrument sets specifically designed ...","pack_size":"Individual","size_variables":["57mm"],"created_at":"2026-03-24T18:07:12.125370+00:00","updated_at":"2026-03-26T14:44:33.832379+00:00","division_canonical":"Trauma","division_live_original":"Trauma","category":"Distal Radial Plates","material_canonical":"Titanium (Pure/CP)","material_live_original":"TiCP","manufacturer":"Meril Life Sciences","description_live":"The ARMAR 2.4 Locking Distal Radial Plate System - Straight is a precision-engineered TiCP (Titanium Commercially Pure) trauma fixation device designed for optimal distal radius fracture management. This 57mm straight plate features 1.6mm thickness with 6-hole configuration, providing superior angular stability and bone-plate interface compression. The biocompatible titanium construction ensures excellent osseointegration while minimizing inflammatory response, making it ideal for complex wrist trauma cases requiring reliable internal fixation.","technical_specifications":{"Material":"TiCP (Titanium Alloy)","Plate Type":"LPS Volar Rim Distal Radial Plate","Thickness":"2.0mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 19.5 mm Right":"MT-PT6802042R: Holes: 6, Shaft Holes: 2, Length: 42mm; MT-PT6803051R: Holes: 6, Shaft Holes: 3, Length: 51mm; MT-PT6804063R: Holes: 6, Shaft Holes: 4, Length: 63mm; MT-PT6805072R: Holes: 6, Shaft Holes: 5, Length: 72mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 19.5 mm Left":"MT-PT6802042L: Holes: 6, Shaft Holes: 2, Length: 42mm; MT-PT6803051L: Holes: 6, Shaft Holes: 3, Length: 51mm; MT-PT6804063L: Holes: 6, Shaft Holes: 4, Length: 63mm; MT-PT6805072L: Holes: 6, Shaft Holes: 5, Length: 72mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 22.5 mm Right":"MT-PT6902045R: Holes: 6, Shaft Holes: 2, Length: 45mm; MT-PT6903054R: Holes: 6, Shaft Holes: 3, Length: 54mm; MT-PT6904066R: Holes: 6, Shaft Holes: 4, Length: 66mm; MT-PT6905075R: Holes: 6, Shaft Holes: 5, Length: 75mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 22.5 mm Left":"MT-PT6902045L: Holes: 6, Shaft Holes: 2, Length: 45mm; MT-PT6903054L: Holes: 6, Shaft Holes: 3, Length: 54mm; MT-PT6904066L: Holes: 6, Shaft Holes: 4, Length: 66mm; MT-PT6905075L: Holes: 6, Shaft Holes: 5, Length: 75mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 25.5 mm Right":"MT-PT7002047R: Holes: 7, Shaft Holes: 2, Length: 47mm; MT-PT7003056R: Holes: 7, Shaft Holes: 3, Length: 56mm; MT-PT7004068R: Holes: 7, Shaft Holes: 4, Length: 68mm; MT-PT7005077R: Holes: 7, Shaft Holes: 5, Length: 77mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 25.5 mm Left":"MT-PT7002047L: Holes: 7, Shaft Holes: 2, Length: 47mm; MT-PT7003056L: Holes: 7, Shaft Holes: 3, Length: 56mm; MT-PT7004068L: Holes: 7, Shaft Holes: 4, Length: 68mm; MT-PT7005077L: Holes: 7, Shaft Holes: 5, Length: 77mm","2.4mm LPS Volar Rim Distal Radial Plate Right":"MT-PT7106057R: Holes: 6, Shaft Holes: 5, Length: 57mm; MT-PT7107057R: Holes: 7, Shaft Holes: 5, Length: 57mm","2.4mm LPS Volar Rim Distal Radial Plate Left":"MT-PT7106057L: Holes: 6, Shaft Holes: 5, Length: 57mm; MT-PT7107057L: Holes: 7, Shaft Holes: 5, Length: 57mm"},"brand":"","parent_brand":"","description_shadow":"2.4mm Locking Distal Radial Plate for fractures, bone tumor and deformities. They boast of high fatigue strength, proper fixation and negligible soft tissue damage.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"low","review_required":true,"match_method":"fuzzy_token","match_score":0.455,"catalog_created_at":"2026-03-27T16:50:59.519375+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"ARMAR 2.4 Locking Distal Radial Plate System - Straight","proposed_clinical_subtitle":"TiCP Locking Plate for Distal Radius Fracture Fixation","proposed_conflict_detected":true,"proposed_enriched_at":"2026-03-28T04:44:33.861369+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly identifies this as ARMAR brand 2.4 locking distal radial plate system with specific specs (57mm, 1.6mm thickness, 6 holes, TiCP). However, external tier1 manufacturer evidence shows Auric (not Meril) as manufacturer of 2.4mm LPS Distal Radial Plates with different thickness spec (2.0mm vs 1.6mm). Meril source references KET Plate system, not ARMAR. Brand ownership conflict exists: internal claims Meril as manufacturer, but ARMAR may be a different manufacturer's brand or distributor brand. Thickness discrepancy (1.6mm internal vs 2.0mm Auric standard) requires verification. The 'Straight' designation appears valid for plate geometry variant. Entity type is product_family as this represents a specific system variant with defined specifications. Recommend review to: 1) Confirm true manufacturer (Meril vs Auric vs other), 2) Verify 1.6mm thickness specification, 3) Clarify ARMAR brand ownership and relationship to manufacturer.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Distal Radius","Wrist"],"proposed_semantic_brand_system":"ARMAR","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"ARMAR 2.4 Locking Distal Radial Plate System","proposed_semantic_implant_class":"Distal Radial Locking Plate","proposed_semantic_material_default":"Titanium CP (Commercially Pure)","proposed_semantic_parent_brand":"ARMAR","proposed_semantic_procedure_scope":["Distal Radius Fracture Fixation","Extra-articular Fracture Management","Trauma Fixation"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Locking Plate System","proposed_semantic_use_case_tags":["distal radius fracture","extra-articular fracture","locking plate fixation","angular stability","trauma fixation"],"proposed_web_verification_status":"review_required_ambiguity","clinical_indications":["Fractures","Bone tumors","Deformities"],"materials_canonical":"TiCP (Titanium Alloy)","features_list":["High fatigue strength","Proper fixation","Negligible soft tissue damage"],"brochure_intelligence_updated":true}}]
