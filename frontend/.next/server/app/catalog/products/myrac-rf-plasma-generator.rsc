orm for ENT. Low-temperature plasma technology. Dual function modes (ablation/coagulation). Integrated saline irrigation & suction.","division_shadow_original":"ENT","shadow_product_id":"4a1ce7de220ca133","shadow_source_files":["ENT All Product Portfolio .pdf"],"shadow_source_pages":["7"],"shadow_sku_count":3,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"family_brand_division","match_score":0.75,"catalog_created_at":"2026-03-27T16:50:59.474501+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"MYRAC by Meril","proposed_clinical_display_title":"MYRAC RF Plasma Generator","proposed_clinical_subtitle":"Radiofrequency Plasma Ablation and Coagulation System for ENT Procedures","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:20:14.619686+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"Internal and external evidence consistently identify MYRAC as an RF plasma generator/electrosurgical device for ENT soft tissue procedures, specifically tonsillectomy and adenoidectomy. This is capital equipment (generator) that produces low-temperature plasma energy for tissue ablation and coagulation. The brochure confirms dual-mode functionality (ablation/coagulation) with integrated saline irrigation and suction. External tier-1 manufacturer sources verify it as an ablation device using minimally invasive, low thermal technique. This is not an implant or consumable but rather a reusable surgical generator/control unit. The SKU examples (TMYC-001/002/003) represent different generator models or configurations. Classification as 'Surgical Instrument' is appropriate for catalog purposes, though technically it is capital equipment. Current title and classification are accurate and clinically appropriate.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Tonsils","Adenoids","Pharynx","Nasopharynx"],"proposed_semantic_brand_system":"MYRAC","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MYRAC RF Plasma System","proposed_semantic_implant_class":"N/A - Capital Equipment","proposed_semantic_material_default":null,"proposed_semantic_parent_brand":"Meril ENT","proposed_semantic_procedure_scope":["Tonsillectomy","Adenoidectomy","Soft Tissue Ablation","Hemostasis"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"RF Electrosurgical Generator","proposed_semantic_use_case_tags":["Low-Temperature Plasma","Minimally Invasive","Electrosurgical Ablation","Coagulation","Tissue Removal","Integrated Irrigation","Integrated Suction"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Tonsils","Adenoids","Pharynx","Nasopharynx"],"semantic_brand_system":"MYRAC","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.441035+00:00","semantic_implant_class":"N/A - Capital Equipment","semantic_material_default":null,"semantic_parent_brand":"Meril ENT","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"RF Electrosurgical Generator"}}]
