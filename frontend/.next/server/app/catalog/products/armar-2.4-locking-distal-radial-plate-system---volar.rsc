1e:["$","$L22",null,{"product":{"product_name":"ARMAR 2.4 Locking Distal Radial Plate System - Volar","product_name_display":"2.4 Locking Distal Radial Plate System - Volar","sku_code":"MRL-ARM-001","product_family":"ARMAR 2.4 Locking Distal Radial Plate System - Volar","product_family_display":"ARMAR 2.4 Locking Distal Radial Plate System - Volar","slug":"armar-2.4-locking-distal-radial-plate-system---volar","images":[{"id":"armar_bp_001","storage_path":"/assets/renders/armar_distal_radius_blueprint.png","original_filename":"armar_distal_radius_blueprint.png","content_type":"image/png","source":"manual_render","width":1024,"height":1024}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"2.4 Locking Distal Radial Plate System - Volar | Meril Distal Radial Plates - MedDevice Pro Telangana","seo_meta_description":"The ARMAR™ Orthopedic Trauma System provides a comprehensive range of titanium locking plates, screws, and specialized instrument sets specifically designed ...","pack_size":"Individual","size_variables":["43mm","61mm"],"created_at":"2026-03-24T18:07:12.124901+00:00","updated_at":"2026-03-26T14:44:33.832087+00:00","division_canonical":"Trauma","division_live_original":"Trauma","category":"Distal Radial Plates","material_canonical":"Titanium (Pure/CP)","material_live_original":"TiCP","manufacturer":"Meril Life Sciences","description_live":"The ARMAR 2.4 Locking Distal Radial Plate System - Volar is a precision-engineered TiCP (Titanium Commercially Pure) trauma implant designed for optimal distal radius fracture fixation. This advanced locking plate system features 2.0mm thickness construction with multiple shaft hole configurations, available in lengths ranging from 43-61mm to accommodate diverse patient anatomies. The volar approach design ensures superior biomechanical stability while minimizing soft tissue irritation, making it ideal for complex fracture patterns requiring reliable internal fixation.","technical_specifications":{"Material":"TiCP (Titanium Alloy)","Plate Type":"LPS Volar Rim Distal Radial Plate","Thickness":"2.0mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 19.5 mm Right":"MT-PT6802042R: Holes: 6, Shaft Holes: 2, Length: 42mm; MT-PT6803051R: Holes: 6, Shaft Holes: 3, Length: 51mm; MT-PT6804063R: Holes: 6, Shaft Holes: 4, Length: 63mm; MT-PT6805072R: Holes: 6, Shaft Holes: 5, Length: 72mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 19.5 mm Left":"MT-PT6802042L: Holes: 6, Shaft Holes: 2, Length: 42mm; MT-PT6803051L: Holes: 6, Shaft Holes: 3, Length: 51mm; MT-PT6804063L: Holes: 6, Shaft Holes: 4, Length: 63mm; MT-PT6805072L: Holes: 6, Shaft Holes: 5, Length: 72mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 22.5 mm Right":"MT-PT6902045R: Holes: 6, Shaft Holes: 2, Length: 45mm; MT-PT6903054R: Holes: 6, Shaft Holes: 3, Length: 54mm; MT-PT6904066R: Holes: 6, Shaft Holes: 4, Length: 66mm; MT-PT6905075R: Holes: 6, Shaft Holes: 5, Length: 75mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 22.5 mm Left":"MT-PT6902045L: Holes: 6, Shaft Holes: 2, Length: 45mm; MT-PT6903054L: Holes: 6, Shaft Holes: 3, Length: 54mm; MT-PT6904066L: Holes: 6, Shaft Holes: 4, Length: 66mm; MT-PT6905075L: Holes: 6, Shaft Holes: 5, Length: 75mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 25.5 mm Right":"MT-PT7002047R: Holes: 7, Shaft Holes: 2, Length: 47mm; MT-PT7003056R: Holes: 7, Shaft Holes: 3, Length: 56mm; MT-PT7004068R: Holes: 7, Shaft Holes: 4, Length: 68mm; MT-PT7005077R: Holes: 7, Shaft Holes: 5, Length: 77mm","2.4mm LPS Double-Column Distal Radial Plate, Volar 25.5 mm Left":"MT-PT7002047L: Holes: 7, Shaft Holes: 2, Length: 47mm; MT-PT7003056L: Holes: 7, Shaft Holes: 3, Length: 56mm; MT-PT7004068L: Holes: 7, Shaft Holes: 4, Length: 68mm; MT-PT7005077L: Holes: 7, Shaft Holes: 5, Length: 77mm","2.4mm LPS Volar Rim Distal Radial Plate Right":"MT-PT7106057R: Holes: 6, Shaft Holes: 5, Length: 57mm; MT-PT7107057R: Holes: 7, Shaft Holes: 5, Length: 57mm","2.4mm LPS Volar Rim Distal Radial Plate Left":"MT-PT7106057L: Holes: 6, Shaft Holes: 5, Length: 57mm; MT-PT7107057L: Holes: 7, Shaft Holes: 5, Length: 57mm"},"brand":"","parent_brand":"","description_shadow":"2.4mm Locking Distal Radial Plate for fractures, bone tumor and deformities. They boast of high fatigue strength, proper fixation and negligible soft tissue damage.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"low","review_required":true,"match_method":"fuzzy_token","match_score":0.455,"catalog_created_at":"2026-03-27T16:50:59.518119+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"ARMAR 2.4 Locking Distal Radial Plate System - Volar","proposed_clinical_subtitle":"Titanium Volar Locking Plate System for Distal Radius Fracture Fixation","proposed_conflict_detected":true,"proposed_enriched_at":"2026-03-28T04:44:18.142486+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly identifies this as the ARMAR 2.4 Locking Distal Radial Plate System - Volar from Meril Life Sciences. However, external source_1 references 'Auric Brochure' with similar specifications (2.4mm, TiCP, 2.0mm thickness, volar distal radial plate), suggesting potential brand confusion. The technical specifications align (2.4mm platform, Titanium, 2.0mm thickness, volar approach, distal radius), but the brand attribution conflicts. ARMAR may be Meril's brand while Auric could be a competitor or distributor variant. Entity type is confirmed as product_family due to multiple length options (43-61mm) and shaft hole configurations. Recommended for review to resolve brand attribution conflict between ARMAR (internal) and Auric (external tier1) before publication. Core clinical meaning is clear: volar locking plate system for distal radius fractures with 2.4mm screw platform.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Distal Radius","Wrist"],"proposed_semantic_brand_system":"ARMAR","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.82,"proposed_semantic_family_group":"ARMAR Distal Radial Plate Systems","proposed_semantic_implant_class":"Distal Radial Volar Locking Plate","proposed_semantic_material_default":"Titanium (Commercially Pure)","proposed_semantic_parent_brand":"ARMAR","proposed_semantic_procedure_scope":["Distal Radius Fracture Fixation","Volar Plating","Open Reduction Internal Fixation (ORIF)"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Locking Plate System","proposed_semantic_use_case_tags":["distal radius fractures","volar approach","locking compression","variable length options","2.4mm screw platform"],"proposed_web_verification_status":"externally_enriched","clinical_indications":["Fractures","Bone tumors","Deformities"],"materials_canonical":"TiCP (Titanium Alloy)","features_list":["High fatigue strength","Proper fixation","Negligible soft tissue damage"],"brochure_intelligence_updated":true,"visual_style":"cool_surgical_blue"}}]
