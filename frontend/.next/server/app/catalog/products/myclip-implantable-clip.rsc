les":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.778556+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Edge-to-edge mitral leaflet clip with dual-row grasper technology","proposed_clinical_display_title":"MyClip Transcatheter Mitral Valve Repair System","proposed_clinical_subtitle":"Edge-to-edge mitral leaflet clip with dual-row grasper technology","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:51:22.184767+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Internal evidence strongly indicates this is a transcatheter mitral valve repair clip system (edge-to-edge leaflet approximation device). The technical specifications—CoCr arms with polyester fabric, NiTi graspers with 2-row anti-slip bristles, radiopaque markers, multiple sizes—are pathognomonic for a MitraClip-type device. However, without external verification or product literature, I cannot confirm: (1) whether MyClip is the actual brand name or a generic descriptor, (2) whether this is Meril's TMVr device or a different system, (3) exact indications and sizing matrix. The division (Cardiovascular/Interventional Cardiology) and technical features align with structural heart intervention. Recommend clinical review to confirm brand identity, obtain IFU/technical specifications, and verify this is not confused with other clip systems (e.g., PASCAL, TriClip for tricuspid). Confidence set at 0.75 due to strong technical alignment but lack of external corroboration.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Mitral Valve","Left Atrium"],"proposed_semantic_brand_system":"MyClip","proposed_semantic_coating_default":"Polyester fabric covering on arms","proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"Structural Heart - Mitral Valve Repair","proposed_semantic_implant_class":"Percutaneous Mitral Valve Clip","proposed_semantic_material_default":"Cobalt-Chromium (CoCr) arms, Nitinol (NiTi) graspers","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Transcatheter Mitral Valve Repair","Edge-to-edge leaflet approximation","MitraClip-equivalent procedure"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Transcatheter Mitral Valve Repair (TMVr)","proposed_semantic_use_case_tags":["Mitral Regurgitation","Degenerative MR","Functional MR","Edge-to-edge repair","Percutaneous valve repair"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Mitral Valve","Left Atrium"],"semantic_brand_system":"MyClip","semantic_coating_default":"Polyester fabric covering on arms","semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.153348+00:00","semantic_implant_class":"Percutaneous Mitral Valve Clip","semantic_material_default":"Cobalt-Chromium (CoCr) arms, Nitinol (NiTi) graspers","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Transcatheter Mitral Valve Repair (TMVr)"}}]
