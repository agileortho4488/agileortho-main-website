as an implant_class (specific valve position) under the product_family (Flomero Pericardial Bioprostheses). The current title accurately reflects the clinical reality: a mitral position-specific bioprosthetic heart valve. No conflicts detected between internal specifications and external manufacturer verification. Classification confirmed with high confidence.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Mitral Valve","Left Atrioventricular Valve"],"proposed_semantic_brand_system":"Flomero","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Flomero Pericardial Bioprostheses","proposed_semantic_implant_class":"Bioprosthetic Heart Valve","proposed_semantic_material_default":"Bovine Pericardium","proposed_semantic_parent_brand":"Flomero Pericardial Bioprostheses","proposed_semantic_procedure_scope":["Mitral Valve Replacement","Open Heart Surgery","Cardiac Valve Replacement Surgery"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Surgical Heart Valve System","proposed_semantic_use_case_tags":["Mitral Valve Disease","Mitral Regurgitation","Mitral Stenosis","Valve Replacement","MR Conditional"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Mitral Valve","Left Atrioventricular Valve"],"semantic_brand_system":"Flomero","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.489952+00:00","semantic_implant_class":"Bioprosthetic Heart Valve","semantic_material_default":"Bovine Pericardium","semantic_parent_brand":"Flomero Pericardial Bioprostheses","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Surgical Heart Valve System"}}]
