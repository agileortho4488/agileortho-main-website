1a:["$","$L1d",null,{"product":{"product_name":"Inviro Surface and Equipment Disinfectant","product_name_display":"Inviro Surface and Equipment Disinfectant","sku_code":"MRL-INF-002","product_family":"Inviro Surface and Equipment Disinfectant","product_family_display":"Inviro Surface and Equipment Disinfectant","slug":"inviro-surface-and-equipment-disinfectant","images":[{"id":"fda23c301567","storage_path":"agile-ortho/products/69c17bd504841ec9248cfade/cover_2f78c6f5.jpg","original_filename":"cover_Surgical Gowns Brochure 27-09-2025.pdf.jpg","content_type":"image/jpeg","size":262286,"uploaded_at":"2026-03-26T05:58:30.484849+00:00","source":"division_fallback","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"Inviro Surface and Equipment Disinfectant | Inviro Surface Disinfectants - MedDevice Pro Telangana","seo_meta_description":"Inviro Surface and Equipment Disinfectant is a powerful multi-alcohol compound formulation containing 10% ethanol, 9% isopropanol, and 6% propanol for compre...","pack_size":"Not specified","size_variables":[],"created_at":"2026-03-25T13:10:59.267085+00:00","updated_at":"2026-03-26T14:44:33.856770+00:00","division_canonical":"Infection Prevention","division_live_original":"Infection Prevention","category":"Surface Disinfectants","material_canonical":"Multi-alcohol compound","material_live_original":"Multi-alcohol compound","manufacturer":"Meril Life Sciences","description_live":"Inviro Surface and Equipment Disinfectant is a powerful multi-alcohol compound formulation containing 10% ethanol, 9% isopropanol, and 6% propanol for comprehensive healthcare surface disinfection. This alcohol-based disinfectant provides rapid antimicrobial action against bacteria, viruses, and fungi on medical equipment and hospital surfaces. Designed for infection prevention protocols, it ensures effective sanitization of critical care areas, surgical instruments, and high-touch surfaces. The multi-alcohol formulation delivers superior disinfection efficacy while maintaining surface compatibility for medical devices.","technical_specifications":{"ethanol_concentration":"10%","isopropanol_concentration":"9%","propanol_concentration":"6%","type":"Alcohol based"},"brand":"Inviro","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.602723+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"Inviro Surface and Equipment Disinfectant","proposed_clinical_subtitle":"Multi-Alcohol Surface Disinfectant for Healthcare Environments","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:00:01.460394+00:00","proposed_entity_type":"consumable","proposed_reasoning_summary":"This is a surface disinfectant consumable product, not a medical device implant or instrument. Internal evidence clearly defines it as a multi-alcohol compound surface disinfectant (10% ethanol, 9% isopropanol, 6% propanol) for healthcare environmental surfaces and medical equipment. External evidence confirms Meril Life Sciences manufactures infection prevention products through their 360 Infection Prevention division. The product name 'Inviro' appears to be the brand designation for this disinfectant line. Classification as a consumable surface disinfectant is appropriate. No anatomy scope applies as this is an environmental surface product. The current title and categorization are clinically accurate. Brand enrichment added based on external verification of Meril's infection prevention portfolio. No conflicts detected between internal product description and external manufacturer verification.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Not Applicable - Environmental Surface Use"],"proposed_semantic_brand_system":"Inviro","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Inviro Surface and Equipment Disinfectant","proposed_semantic_implant_class":"Not Applicable","proposed_semantic_material_default":"Multi-alcohol compound (10% ethanol, 9% isopropanol, 6% propanol)","proposed_semantic_parent_brand":"Meril 360 Infection Prevention","proposed_semantic_procedure_scope":["Environmental Surface Disinfection","Medical Equipment Disinfection","Infection Prevention Protocols"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Surface Disinfection","proposed_semantic_use_case_tags":["Surface Disinfection","Equipment Disinfection","Healthcare Environmental Hygiene","Infection Prevention","Antimicrobial Surface Treatment","Hospital Surface Cleaning","Multi-Alcohol Formulation"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Not Applicable - Environmental Surface Use"],"semantic_brand_system":"Inviro","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.463950+00:00","semantic_implant_class":"Not Applicable","semantic_material_default":"Multi-alcohol compound (10% ethanol, 9% isopropanol, 6% propanol)","semantic_parent_brand":"Meril 360 Infection Prevention","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Surface Disinfection"}}]
