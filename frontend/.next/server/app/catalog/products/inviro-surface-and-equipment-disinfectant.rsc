13:T402,{"@context":"https://schema.org/","@type":"Product","name":"Inviro Surface and Equipment Disinfectant","description":"Inviro Surface and Equipment Disinfectant is a powerful multi-alcohol compound formulation containing 10% ethanol, 9% isopropanol, and 6% propanol for comprehensive healthcare surface disinfection. This alcohol-based disinfectant provides rapid antimicrobial action against bacteria, viruses, and fungi on medical equipment and hospital surfaces. Designed for infection prevention protocols, it ensures effective sanitization of critical care areas, surgical instruments, and high-touch surfaces. The multi-alcohol formulation delivers superior disinfection efficacy while maintaining surface compatibility for medical devices.","brand":{"@type":"Brand","name":"Meril"},"category":"Surface Disinfectants","manufacturer":{"@type":"Organization","name":"Meril Life Sciences"},"offers":{"@type":"AggregateOffer","offerCount":"1","lowPrice":"0","priceCurrency":"INR","availability":"https://schema.org/InStock"}}7:["$","div",null,{"className":"min-h-screen bg-[#0A0A0A] text-white","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$13"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://agileortho.in\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Catalog\",\"item\":\"https://agileortho.in/catalog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Infection Prevention\",\"item\":\"https://agileortho.in/catalog/infection-prevention\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Inviro Surface and Equipment Disinfectant\",\"item\":\"https://agileortho.in/catalog/products/inviro-surface-and-equipment-disinfectant\"}]}"}}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24","c