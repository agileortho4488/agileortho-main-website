brand_system":"MyClip TEER System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MyClip TEER System Accessories","proposed_semantic_implant_class":"N/A - Procedural Accessories","proposed_semantic_material_default":"Mixed materials (silicone, metal)","proposed_semantic_parent_brand":"MyClip","proposed_semantic_procedure_scope":["Transcatheter Edge-to-Edge Repair (TEER)","Transcatheter Mitral Valve Repair","Structural Heart Intervention"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Transcatheter Edge-to-Edge Repair (TEER) System Accessories","proposed_semantic_use_case_tags":["procedural setup","stability platform","positioning accessories","cathlab equipment","interventional cardiology accessories"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Mitral Valve"],"semantic_brand_system":"MyClip TEER System","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.493141+00:00","semantic_implant_class":"N/A - Procedural Accessories","semantic_material_default":"Mixed materials (silicone, metal)","semantic_parent_brand":"MyClip","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Transcatheter Edge-to-Edge Repair (TEER) System Accessories"}}]
