ure_scope":["Fracture Fixation","Osteotomy","Arthrodesis"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Multi-Angle Locking Plate System","proposed_semantic_use_case_tags":["Multi-Angle Locking","Variable Angle Fixation","Small Fragment Trauma","Self-Tapping"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Small Bone","Hand","Wrist","Foot","Ankle"],"semantic_brand_system":"Variabilis Multi-Angle Plates","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.053831+00:00","semantic_implant_class":"Locking Screw","semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","semantic_parent_brand":"Variabilis","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Multi-Angle Locking Plate System"}}]
