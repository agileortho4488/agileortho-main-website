1c:T489,This is a specific size variant (8F, 35cc) of an intra-aortic balloon catheter, which is a temporary hemodynamic support device, not an implantable device in the permanent sense. Entity type is 'implant_class' as this represents a distinct clinical device configuration within the MYOSIST family. Internal evidence provides comprehensive technical specifications (balloon volume 35cc, 8F profile, 227mm balloon length, patient height 155-165cm). External tier-1 manufacturer sources confirm MYOSIST is Meril's IABP catheter line used for hemodynamic support during cardiac procedures. The device is placed in the descending aorta and operated with an IABP pump for counterpulsation therapy. All sources align consistently. Brand is MYOSIST (not missing, it's the product system name). Recommended action is 'rename' to remove 'Kit' from title as this is a single catheter device specification, though it may be packaged as a kit. The current title format suggests it's a kit, but clinically this is referenced by its catheter specifications. Material (polyurethane), dimensions, and patient height range are all verified. High confidence, no conflicts detected.17:["$","$L1b",null,{"product":{"product_name":"MYOSIST Intra Aortic Balloon Catheter Kit 8F (35cc)","product_name_display":"MYOSIST Intra-Aortic Balloon Catheter 8F (35cc)","sku_code":"MYS0835","product_family":"MYOSIST Intra Aortic Balloon Catheters","product_family_display":"MYOSIST Intra Aortic Balloon Catheters","slug":"myosist-intra-aortic-balloon-catheter-kit-8f-(35cc)","images":[{"id":"prop_69c3ed7","storage_path":"agile-ortho/products/69c3ed722a7174181a7c3eaf/cover_054cc79b.jpg","original_filename":"cover_MYOSIST Brochure.pdf.jpg","content_type":"image/jpeg","size":397849,"uploaded_at":"2026-03-26T05:56:55.105541+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MYOSIST Intra-Aortic Balloon Catheter 8F (35cc) | MYOSIST Intra-Aortic Balloon Pumps - MedDevice Pro Telangana","seo_meta_description":"The MYOSIST™ Intra Aortic Balloon Catheter Kit (8F) is a high-performance hemodynamic support system designed for patients with critical cardiac conditions. ...","pack_size":"Kit","size_variables":["35cc"],"created_at":"2026-03-25T14:13:06.265407+00:00","updated_at":"2026-03-26T14:44:33.888240+00:00","division_canonical":"Cardiovascular","division_live_original":"Cardiovascular","category":"Intra-Aortic Balloon Pumps","material_canonical":"Polyurethane","material_live_original":"Polyurethane","manufacturer":"Meril Life Sciences","description_live":"MYOSIST Intra Aortic Balloon Catheter Kit 8F features a 35cc polyurethane balloon designed for hemodynamic support in cardiovascular procedures. The 8 French profile catheter offers optimal deliverability with 227mm balloon length and 870mm total catheter length, suitable for patients 155-165cm height. Compatible with 0.025\" guidewires and engineered for reliable IABP therapy with maximum dilation pressure of 5 PSI.","technical_specifications":{"Balloon Volume 30cc Specifications":"Catalog #: MYS0830, Diameter: 14.5mm, Balloon Length: 225mm, Patient Height: 145-155cm","Balloon Volume 35cc Specifications":"Catalog #: MYS0835, Diameter: 15mm, Balloon Length: 227mm, Patient Height: 155-165cm","Balloon Volume 40cc Specifications":"Catalog #: MYS0840, Diameter: 15mm, Balloon Length: 259mm, Patient Height: >165cm","Balloon Catheter Length":"870 mm","Balloon Catheter Usable Length":"710 mm","Catheter Profile (French)":"8","Inner Lumen ID":"0.028 inch","Guidewire Compatibility":"0.025 inch","Nominal Pressure":"2 PSI","Maximum Dilation Pressure":"5 PSI","Datascope Console Compatibility":"System 97, 98, 98XT, CS 100, CS 300, CardioSave","Arrow Console Compatibility":"ACAT, AutoCAT, AutoCAT 2, AutoCAT 2 Wave, KAAT II","Balloon Material":"Polyurethane"},"brand":"MYOSIST","parent_brand":"","description_shadow":"The MYOSIST™ Intra Aortic Balloon Catheter Kit (8F) is a high-performance hemodynamic support system designed for patients with critical cardiac conditions. It features a polyurethane balloon membrane tested for 1 million inflation-deflation cycles, providing durability and reliable performance during counterpulsation therapy.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.642269+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Polyurethane balloon catheter for hemodynamic support, 155-165cm patient height","proposed_clinical_display_title":"MYOSIST Intra-Aortic Balloon Catheter 8F (35cc)","proposed_clinical_subtitle":"Polyurethane balloon catheter for hemodynamic support, 155-165cm patient height","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:17:55.217029+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"$1c","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Descending Aorta","Arterial Vasculature"],"proposed_semantic_brand_system":"MYOSIST","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MYOSIST Intra-Aortic Balloon Catheters","proposed_semantic_implant_class":"Intra-Aortic Balloon Catheter","proposed_semantic_material_default":"Polyurethane","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Cardiac Surgery Support","Hemodynamic Support","IABP Therapy","Cardiogenic Shock Management"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Intra-Aortic Balloon Pump System","proposed_semantic_use_case_tags":["Hemodynamic Support","Counterpulsation Therapy","Cardiac Surgery","Critical Care Cardiology","IABP Therapy"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Descending Aorta","Arterial Vasculature"],"semantic_brand_system":"MYOSIST","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.486455+00:00","semantic_implant_class":"Intra-Aortic Balloon Catheter","semantic_material_default":"Polyurethane","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Intra-Aortic Balloon Pump System","clinical_indications":["Cardiogenic Shock","CABG (Coronary artery bypass grafting)","Hemodynamically Unstable Infarction","CVTS (Cardiovascular and Thoracic Surgery)"],"materials_canonical":"Polyurethane","features_list":["Highly Durable & Flexible Balloon Membrane tested for 1 million cycles","Radio-opaque Catheter Tip & Markers for easy location of deployment","Optimized 710mm insertion length","0.028 inch Inner Lumen Diameter for excellent arterial pressure measurement","Greater hemodynamic support for every patient","More blood volume displacement","More diastolic augmentation","More systolic unloading"],"brochure_intelligence_updated":true}}]
