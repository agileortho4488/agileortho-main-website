d navigation capabilities","technical_specifications":{"Catheter System":"Over-the-wire (OTW)","Drug Type":"Paclitaxel","Drug Dosage":"3 µg/mm","Usable Catheter Length":"80 cm & 135 cm","Max. Guidewire Compatibility":"0.035\"","Balloon Diameter (mm)":"3.00, 4.00, 5.00, 6.00, 7.00, 8.00, 9.00 & 10.00 mm","Balloon Length (mm)":"30, 40, 50, 60, 80 & 120 mm","Min. Sheath Compatibility":"5 Fr to 8 Fr","Balloon RO Markers":"2 - Platinum/Iridium","Shaft Diameter":"5 Fr","Nominal Pressure (NP)":"6-7 atm","Rated Burst Pressure (RBP)":"11-14 atm"},"brand":"Mozec","parent_brand":"","description_shadow":"The MOZEC PEB PTA is a Paclitaxel Eluting PTA Balloon Catheter designed on the navigable Mozec PTA platform. It features proprietary drug adhesion technology and offers balloon lengths up to 120mm, allowing for the treatment of long lesions with a single balloon to optimize procedure outcomes.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:51:00.016993+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"Mozec Paclitaxel-Eluting PTA Balloon Catheter","proposed_clinical_subtitle":"Drug-Coated Balloon for Peripheral Artery Disease","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T06:57:35.788308+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence provides comprehensive technical and clinical specification. This is clearly a paclitaxel drug-eluting balloon (DEB) catheter system for peripheral transluminal angioplasty. The 'Mozec' brand name, division placement (Peripheral Intervention), detailed specifications (OTW delivery, 3 µg/mm² paclitaxel coating, 0.035\" guidewire compatibility, 5-8 Fr sheath compatibility, balloon sizes 3-10mm diameter and 30-120mm lengths) all confirm this is a complete product family for treating peripheral artery disease. The PEB (Paclitaxel-Eluting Balloon) and PTA (Percutaneous Transluminal Angioplasty) acronyms in the product ID are standard medical device nomenclature. No external verification needed as internal catalog evidence is clinically complete and consistent. Brand field is empty but 'Mozec' is clearly the brand system from product_family and brochure_heading. No conflicts detected between any data points.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Peripheral arteries","Iliac arteries","Femoral arteries","Popliteal arteries","Tibial arteries"],"proposed_semantic_brand_system":"Mozec","proposed_semantic_coating_default":"Paclitaxel (3 µg/mm²)","proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Mozec Balloon Catheters","proposed_semantic_implant_class":"Paclitaxel-Eluting PTA Balloon Catheter","proposed_semantic_material_default":"Balloon catheter substrate","proposed_semantic_parent_brand":"Mozec","proposed_semantic_procedure_scope":["Percutaneous Transluminal Angioplasty (PTA)","Peripheral artery intervention","Treatment of peripheral artery disease"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Drug-Eluting Balloon Catheter System","proposed_semantic_use_case_tags":["Drug-coated balloon","Peripheral vascular intervention","Antiproliferative therapy","In-stent restenosis prevention","De novo lesion treatment"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Peripheral arteries","Iliac arteries","Femoral arteries","Popliteal arteries","Tibial arteries"],"semantic_brand_system":"Mozec","semantic_coating_default":"Paclitaxel (3 µg/mm²)","semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.538097+00:00","semantic_implant_class":"Paclitaxel-Eluting PTA Balloon Catheter","semantic_material_default":"Balloon catheter substrate","semantic_parent_brand":"Mozec","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Drug-Eluting Balloon Catheter System","clinical_indications":["Percutaneous Transluminal Angioplasty (PTA)","Treatment of longer vascular lesions","Drug treatment of peripheral arteries"],"materials_canonical":"Paclitaxel (Drug)","features_list":["Longest length 120mm avoids the need for multiple balloons for longer lesions","Proprietary drug adhesion technology ensures no drug loss during loading","Lesser exposure time and faster procedure outcome","Built on the navigable and well-known Mozec PTA balloon platform","Protects the integrity of the drug and excipient"],"brochure_intelligence_updated":true}}]
