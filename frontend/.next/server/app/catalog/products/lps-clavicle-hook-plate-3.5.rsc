7:["$","div",null,{"className":"min-h-screen bg-[#0A0A0A] text-white","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org/\",\"@type\":\"Product\",\"name\":\"LPS Clavicle Hook Plate 3.5\",\"description\":\"The LPS Clavicle Hook Plate 3.5 is a premium titanium (TiCP) orthopedic implant designed for superior acromioclavicular joint stabilization and distal clavicle fracture fixation. Featuring a robust 4.0mm thickness and available in 12mm, 15mm, and 18mm depth options, this anatomically contoured plate ensures optimal surgical outcomes. The biocompatible titanium construction provides excellent osseointegration while maintaining the mechanical strength required for effective clavicular reconstruction in complex orthopedic procedures.\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Meril\"},\"category\":\"Clavicle Plates\",\"manufacturer\":{\"@type\":\"Organization\",\"name\":\"Meril Life Sciences\"},\"offers\":{\"@type\":\"AggregateOffer\",\"offerCount\":\"1\",\"lowPrice\":\"0\",\"priceCurrency\":\"INR\",\"availability\":\"https://schema.org/InStock\"}}"}}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24","children":[["$","nav",null,{"className":"flex mb-10 text-sm text-muted-foreground","aria-label":"Breadcrumb","children":[["$","$L12",null,{"href":"/catalog","className":"hover:text-primary transition-colors","children":"Catalog"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","$L12",null,{"href":"/catalog/trauma","className":"hover:text-primary transition-colors","children":"Trauma"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","span",null,{"className":"text-white truncate max-w-[200px]","children":"LPS Clavicle Hook Plate 3.5"}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 mb-16","children":[["$","div",null,{"className":"relative group","children":[["$","div",null,{"className":"absolute -i