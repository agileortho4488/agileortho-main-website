1c:T42c,This is a specific size configuration (8F, 30cc) of an intra-aortic balloon catheter (IABC) within the MYOSIST product family by Meril Life Sciences. Internal evidence provides complete technical specifications including balloon volume (30cc), diameter (14.5mm), catheter profile (8F), and patient height range (145-155cm). External tier1_manufacturer sources confirm MYOSIST is Meril's IABC brand used for hemodynamic support during cardiac surgery and critical care. The device is placed in the descending aorta and operates with an IAB pump to provide counterpulsation therapy. The polyurethane material is verified with documented durability (1 million cycle testing). This represents a specific catheter size/volume variant, not a family page, as it has precise dimensional specifications for a defined patient population. All sources align without conflict. Classification as 'implant_class' entity is appropriate as this is a temporary intravascular device, not permanently implanted. Title simplified to remove 'Kit' as the core product is the catheter itself.17:["$","$L1b",null,{"product":{"product_name":"MYOSIST Intra Aortic Balloon Catheter Kit 8F (30cc)","product_name_display":"MYOSIST Intra Aortic Balloon Catheter Kit 8F (30cc)","sku_code":"MYS0830","product_family":"MYOSIST Intra Aortic Balloon Catheters","product_family_display":"MYOSIST Intra Aortic Balloon Catheters","slug":"myosist-intra-aortic-balloon-catheter-kit-8f-(30cc)","images":[{"id":"3ed33f9c7f87","storage_path":"agile-ortho/products/69c3ed722a7174181a7c3eaf/cover_054cc79b.jpg","original_filename":"cover_MYOSIST Brochure.pdf.jpg","content_type":"image/jpeg","size":397849,"uploaded_at":"2026-03-26T05:56:55.105541+00:00","source":"brochure_extraction","width":1654,"height":2339},{"id":"21aab1dff7a6","storage_path":"agile-ortho/products/69c3ed722a7174181a7c3eaf/cover_bd5febaa.jpg","original_filename":"cover_MYOSIST Brochure.pdf.jpg","content_type":"image/jpeg","size":397849,"uploaded_at":"2026-03-26T06:01:56.881505+00:00","source":"brochure_extraction","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MYOSIST Intra Aortic Balloon Catheter Kit 8F (30cc) | MYOSIST Intra-Aortic Balloon Pumps - MedDevice Pro Telangana","seo_meta_description":"The MYOSIST™ Intra Aortic Balloon Catheter Kit (8F) is a high-performance hemodynamic support system designed for patients with critical cardiac conditions. ...","pack_size":"Kit","size_variables":["30cc"],"created_at":"2026-03-25T14:13:06.264969+00:00","updated_at":"2026-03-26T14:44:33.887939+00:00","division_canonical":"Cardiovascular","division_live_original":"Cardiovascular","category":"Intra-Aortic Balloon Pumps","material_canonical":"Polyurethane","material_live_original":"Polyurethane","manufacturer":"Meril Life Sciences","description_live":"MYOSIST Intra Aortic Balloon Catheter Kit 8F (30cc) is a premium polyurethane cardiovascular device designed for hemodynamic support in critically ill patients. Features optimal 30cc balloon volume with 14.5mm diameter for patients 145-155cm height, delivering precise counterpulsation therapy. The 8 French profile catheter ensures smooth insertion with 0.028\" inner lumen and 0.025\" guidewire compatibility for enhanced procedural safety.","technical_specifications":{"Balloon Volume 30cc Specifications":"Catalog #: MYS0830, Diameter: 14.5mm, Balloon Length: 225mm, Patient Height: 145-155cm","Balloon Volume 35cc Specifications":"Catalog #: MYS0835, Diameter: 15mm, Balloon Length: 227mm, Patient Height: 155-165cm","Balloon Volume 40cc Specifications":"Catalog #: MYS0840, Diameter: 15mm, Balloon Length: 259mm, Patient Height: >165cm","Balloon Catheter Length":"870 mm","Balloon Catheter Usable Length":"710 mm","Catheter Profile (French)":"8","Inner Lumen ID":"0.028 inch","Guidewire Compatibility":"0.025 inch","Nominal Pressure":"2 PSI","Maximum Dilation Pressure":"5 PSI","Datascope Console Compatibility":"System 97, 98, 98XT, CS 100, CS 300, CardioSave","Arrow Console Compatibility":"ACAT, AutoCAT, AutoCAT 2, AutoCAT 2 Wave, KAAT II","Balloon Material":"Polyurethane"},"brand":"MYOSIST","parent_brand":"","description_shadow":"The MYOSIST™ Intra Aortic Balloon Catheter Kit (8F) is a high-performance hemodynamic support system designed for patients with critical cardiac conditions. It features a polyurethane balloon membrane tested for 1 million inflation-deflation cycles, providing durability and reliable performance during counterpulsation therapy.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.641351+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"MYOSIST Intra-Aortic Balloon Catheter 8F (30cc)","proposed_clinical_subtitle":"Polyurethane balloon catheter for hemodynamic support in patients 145-155cm","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:15:32.091134+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"$1c","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Descending Aorta","Femoral Artery"],"proposed_semantic_brand_system":"MYOSIST","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MYOSIST Intra-Aortic Balloon Catheters","proposed_semantic_implant_class":"Intra-Aortic Balloon Catheter","proposed_semantic_material_default":"Polyurethane","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Cardiac Surgery Support","Cardiogenic Shock Management","Hemodynamic Support","Counterpulsation Therapy"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Intra-Aortic Balloon Pump System","proposed_semantic_use_case_tags":["Hemodynamic Support","Counterpulsation","Critically Ill Patients","Cardiac Surgery","Cardiogenic Shock","Blood Flow Management"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Descending Aorta","Femoral Artery"],"semantic_brand_system":"MYOSIST","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.486028+00:00","semantic_implant_class":"Intra-Aortic Balloon Catheter","semantic_material_default":"Polyurethane","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Intra-Aortic Balloon Pump System","clinical_indications":["Cardiogenic Shock","CABG (Coronary artery bypass grafting)","Hemodynamically Unstable Infarction","CVTS (Cardiovascular and Thoracic Surgery)"],"materials_canonical":"Polyurethane","features_list":["Highly Durable & Flexible Balloon Membrane tested for 1 million cycles","Radio-opaque Catheter Tip & Markers for easy location of deployment","Optimized 710mm insertion length","0.028 inch Inner Lumen Diameter for excellent arterial pressure measurement","Greater hemodynamic support for every patient","More blood volume displacement","More diastolic augmentation","More systolic unloading"],"brochure_intelligence_updated":true}}]
