r","Sample Blank Non Linear"],"resolution":"0.0001","programmable_channels":200,"minimum_reaction_volume":"350 µL","air_gap_aspiration_volume":"0 to 50 µL","temperature_control":"Peltier elements","display":"Large LCD with STN backlight","qc_levels":3,"calibration":"Multipoint calibration with any mode"},"brand":"CliniQuant","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.429,"catalog_created_at":"2026-03-27T16:50:59.693262+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Compact clinical chemistry analyzer with 8 measurement modes and 200 programmable channels","proposed_clinical_display_title":"CliniQuant Micro Semi-Automatic Biochemistry Analyzer","proposed_clinical_subtitle":"Compact clinical chemistry analyzer with 8 measurement modes and 200 programmable channels","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:29:06.085704+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"Internal brochure describes an 8-mode clinical chemistry analyzer with specific technical specifications. External tier1_manufacturer sources confirm this is the 'CliniQuant Micro Semi-Automatic Biochemistry Analyzer' by Meril Life Sciences, designed for small to mid-sized laboratories. The term 'semi-automatic' is consistently used in manufacturer sources and is clinically significant (vs. fully automatic systems). Current title lacks this important qualifier. All sources align: this is a bench-top diagnostic instrument, not an implant, consumable, or reagent. The CliniQuant brand represents Meril's biochemistry analyzer platform. Technical specs (200 programmable channels, 8 measurement modes including absorbance/kinetic/endpoint, Peltier temperature control, 350µL minimum reaction volume) are consistent with semi-automatic biochemistry analyzers. Recommend adding 'Semi-Automatic Biochemistry Analyzer' to title for clinical accuracy and search optimization.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":[],"proposed_semantic_brand_system":"CliniQuant","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"CliniQuant Analyzer Platform","proposed_semantic_implant_class":"N/A - Diagnostic Instrument","proposed_semantic_material_default":null,"proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Clinical Chemistry Testing","Biochemistry Analysis","In Vitro Diagnostics"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Semi-Automatic Biochemistry Analyzer","proposed_semantic_use_case_tags":["Small to mid-sized laboratories","Clinical chemistry","Biochemistry testing","Semi-automatic analysis","Multi-mode measurement","Bench-top analyzer"],"proposed_web_verification_status":"externally_enriched","semantic_anatomy_scope":[],"semantic_brand_system":"CliniQuant","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.499242+00:00","semantic_implant_class":"N/A - Diagnostic Instrument","semantic_material_default":null,"semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_ENRICHED"],"semantic_system_type":"Semi-Automatic Biochemistry Analyzer"}}]]}]]}],false,"$undefined","$L15","$L16"]}]]}]
