17:["$","$L1a",null,{"product":{"product_name":"Maira Surgical Gown Level 2","product_name_display":"Maira Surgical Gown Level 2","sku_code":"MSGSL2","product_family":"Maira Surgical Gowns","product_family_display":"Maira Surgical Gowns","slug":"maira-surgical-gown-level-2","images":[{"id":"prop_69c3ed7","storage_path":"agile-ortho/products/69c17bd504841ec9248cfade/cover_2f78c6f5.jpg","original_filename":"cover_Surgical Gowns Brochure 27-09-2025.pdf.jpg","content_type":"image/jpeg","size":262286,"uploaded_at":"2026-03-26T05:58:30.484849+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"Maira Surgical Gown Level 2 | MAIRA Surgical Gowns - MedDevice Pro Telangana","seo_meta_description":"Maira Surgical Gown Level 2 provides moderate fluid resistance protection for medium-risk surgical procedures in hospital operating theaters. Constructed fro...","pack_size":"50-1000 pieces per pack","size_variables":["S","M","L","XL","XXL","XXXL"],"created_at":"2026-03-25T14:13:06.245228+00:00","updated_at":"2026-03-26T14:44:33.881878+00:00","division_canonical":"Infection Prevention","division_live_original":"Infection Prevention","category":"Surgical Gowns","material_canonical":"Non-Woven Fabric (Medical Grade)","material_live_original":"Non-woven fabric","manufacturer":"Meril Life Sciences","description_live":"Maira Surgical Gown Level 2 provides moderate fluid resistance protection for medium-risk surgical procedures in hospital operating theaters. Constructed from premium non-woven fabric, this infection prevention gown meets AAMI Level 2 standards for barrier protection against blood and bodily fluids. Designed for optimal comfort and sterility maintenance during general surgical procedures, appendectomies, and diagnostic procedures. Essential protective equipment for maintaining aseptic conditions and reducing healthcare-associated infection transmission in surgical environments.","technical_specifications":{"protection_level":"Level 2","fluid_resistance":"Moderate","intended_use":"Medium-risk surgical procedures"},"brand":"MAIRA","parent_brand":"Meril","description_shadow":"","division_shadow_original":"Infection Prevention","shadow_product_id":"5e83044c920a8eb1","shadow_source_files":["360 Infection Prevention Solutions Price List For Distributor with New MRP 19.09.2025 (1).pdf"],"shadow_source_pages":[1],"shadow_sku_count":1,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"exact_sku_link","match_score":1,"catalog_created_at":"2026-03-27T16:50:59.633590+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"MAIRA by Meril","proposed_clinical_display_title":"Maira Surgical Gown Level 2","proposed_clinical_subtitle":"Moderate Barrier Protection for Medium-Risk Surgical Procedures","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:11:05.182920+00:00","proposed_entity_type":"consumable","proposed_reasoning_summary":"Internal evidence clearly identifies this as a disposable surgical gown meeting AAMI Level 2 barrier protection standards. The brochure explicitly states 'moderate fluid resistance protection for medium-risk surgical procedures' and 'meets AAMI Level 2 standards for barrier protection against blood and bodily fluids.' External tier3 and tier4 sources confirm AAMI Level 2 classification corresponds to moderate barrier performance for medium-risk surgical applications. This is a consumable protective device, not an implant. The product serves infection prevention by creating a sterile barrier between surgical personnel and patients during procedures with moderate fluid exposure risk. Material specification (non-woven fabric) is standard for disposable surgical gowns. No conflicts detected between internal brochure data and external AAMI classification standards. Current title accurately reflects the product's clinical identity and regulatory classification.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Full Body Coverage","Critical Zones (Chest/Forearms)"],"proposed_semantic_brand_system":"Maira","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Infection Prevention - Surgical Gowns","proposed_semantic_implant_class":"N/A - Protective Barrier Device","proposed_semantic_material_default":"Non-Woven Polypropylene (Medical Grade)","proposed_semantic_parent_brand":"Maira Surgical Gowns","proposed_semantic_procedure_scope":["General Surgery","Medium-Risk Surgical Procedures","Operating Theater Procedures","Appendectomy","Procedures with Moderate Fluid Exposure"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Single-Use Surgical Protective Apparel","proposed_semantic_use_case_tags":["AAMI Level 2 Protection","Moderate Fluid Resistance","Single-Use Disposable","Sterile Barrier","Operating Room PPE","Blood/Bodily Fluid Barrier","Hospital OR Use"],"proposed_web_verification_status":"externally_enriched","semantic_anatomy_scope":["Full Body Coverage","Critical Zones (Chest/Forearms)"],"semantic_brand_system":"Maira","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.477623+00:00","semantic_implant_class":"N/A - Protective Barrier Device","semantic_material_default":"Non-Woven Polypropylene (Medical Grade)","semantic_parent_brand":"Maira Surgical Gowns","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_ENRICHED"],"semantic_system_type":"Single-Use Surgical Protective Apparel"}}]
