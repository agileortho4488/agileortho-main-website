_required":false,"match_method":"exact_sku_link","match_score":1,"catalog_created_at":"2026-03-27T16:50:59.652771+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"BAKTIO by Meril","proposed_clinical_display_title":"Baktio Pink Hand Sanitizer","proposed_clinical_subtitle":"Alcohol-Based Hand Hygiene Solution","proposed_conflict_detected":true,"proposed_enriched_at":"2026-03-28T04:34:02.971708+00:00","proposed_entity_type":"consumable","proposed_reasoning_summary":"Internal evidence clearly identifies this as Baktio Pink, an alcohol-based hand sanitizer from Meril Life Sciences under the 360 Infection Prevention Solutions portfolio. Product classification as consumable hand hygiene solution is confirmed. However, external source_2 references 'Bactorub Pink' (different spelling) containing Ethanol and Chlorhexidine Gluconate, suggesting potential formulation details not present in internal documentation. The brand name spelling difference (Baktio vs Bactorub) and absence of CHG mention in internal materials creates ambiguity. Internal evidence shows HSN code 38089490 (disinfectants), multiple size formats (100ml flip top example), and pink coloration. Recommend review to: 1) Confirm correct brand spelling, 2) Verify if CHG is actually included in formulation, 3) Clarify if Baktio and Bactorub are same/different products. Classification structure is sound but formulation details need verification before full confidence.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Hand/Skin"],"proposed_semantic_brand_system":"Baktio","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Baktio Pink Hand Hygiene","proposed_semantic_implant_class":"N/A","proposed_semantic_material_default":"Alcohol-based solution","proposed_semantic_parent_brand":"360 Infection Prevention Solutions","proposed_semantic_procedure_scope":["Hand Hygiene","Infection Prevention","Pre-procedural Hand Disinfection"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Hand Hygiene Solution","proposed_semantic_use_case_tags":["Hand Sanitizer","Healthcare Hand Hygiene","Alcohol-Based Rub","Antiseptic Solution","Multi-Size Format"],"proposed_web_verification_status":"review_required_ambiguity"}}]]}]]}],false,"$undefined","$L15","$L16"]}]]}]
