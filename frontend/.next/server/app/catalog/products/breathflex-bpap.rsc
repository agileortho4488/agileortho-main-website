PCV","pressure_range":"4–30 cmH2O","ramp_time":"0–60 minutes (1-minute steps)","backup_rate":"5–60 bpm (±1 bpm)","ie_ratio":"10%–90% (±1%)","humidifier_settings":"Level 0–5 (max 65 °C)","heated_tube_range":"10–30 °C","water_tank_volume":"200 ml","maximum_flow_rate":"≥170 L/min","noise_level":"≤ 30 dB","dimensions":"266.80 × 172.50 × 118.50 mm","weight":"1.9 kg","power_supply":"100–240 V AC, 50/60 Hz, 1.5 A Max","ports":"Micro SD, Type-C, SIM Card"},"brand":"BreathFlex","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.861212+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"BreathFlex BiPAP Non-Invasive Ventilation System","proposed_clinical_subtitle":"Bilevel Positive Airway Pressure Therapy for Sleep Apnea and Hypoventilation","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T06:13:11.030187+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal brochure evidence clearly establishes this as a BiPAP (Bilevel Positive Airway Pressure) ventilation system. The description explicitly states it delivers IPAP and EPAP pressure levels for sleep apnea and hypoventilation management. Technical specifications confirm multiple operating modes (CPAP, AUTO, S, T, ST, APCV), pressure range 4-30 cmH2O, integrated humidifier, and comprehensive monitoring capabilities. This is a complete therapeutic device/product family, not an implant or consumable. The 'BPAP' nomenclature is standard industry terminology (BiPAP is Respironics trademark, BPAP is generic equivalent). Division placement in Critical Care is appropriate as these devices serve both home care and hospital settings. No external verification needed as internal evidence is comprehensive and unambiguous. Brand field empty but manufacturer clearly identified as Meril Life Sciences. High confidence assignment based on detailed technical specifications and clear clinical indication statement.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Upper Airway","Respiratory System"],"proposed_semantic_brand_system":"BreathFlex","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Respiratory Therapy Devices","proposed_semantic_implant_class":"N/A - External Medical Device","proposed_semantic_material_default":null,"proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Non-Invasive Ventilation","Positive Airway Pressure Therapy","Sleep Apnea Management","Hypoventilation Support"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Non-Invasive Ventilation System","proposed_semantic_use_case_tags":["Obstructive Sleep Apnea","Central Sleep Apnea","Mixed Sleep Apnea","Hypoventilation","BiPAP Therapy","CPAP Alternative","Home Respiratory Care","Critical Care Respiratory Support"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Upper Airway","Respiratory System"],"semantic_brand_system":"BreathFlex","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.520234+00:00","semantic_implant_class":"N/A - External Medical Device","semantic_material_default":null,"semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Non-Invasive Ventilation System"}}]
