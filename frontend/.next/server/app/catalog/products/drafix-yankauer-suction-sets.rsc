ce_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.561789+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Oral Suctioning Systems for Surgical and Critical Care","proposed_clinical_display_title":"DRAFIX Yankauer Suction Sets","proposed_clinical_subtitle":"Oral Suctioning Systems for Surgical and Critical Care","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:50:26.887059+00:00","proposed_entity_type":"consumable","proposed_reasoning_summary":"Yankauer suction devices are well-established surgical consumables used for oral/pharyngeal suctioning. Internal brochure correctly identifies application (oral suctioning, OR/ICU), material (medical grade plastic), and clinical context. External tier-4 source confirms standard Yankauer suction set definition. However, brand 'DRAFIX' is not independently verified - Meril ENT portfolio shows airway management solutions but does not specifically list DRAFIX as a branded line. This represents a consumable product family, not an implant class. Classification is enriched but requires review to confirm: (1) DRAFIX brand ownership by Meril, (2) whether this represents a complete product line or should be merged into broader airway management category, (3) verification of specific product configurations within the family. Material and application are standard for Yankauer devices. Recommend review before publication due to unverified brand attribution.","proposed_recommended_action":"send_to_r