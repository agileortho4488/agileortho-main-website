16:["$","$L19",null,{"product":{"product_name":"Libertas Total Hip System","product_name_display":"Libertas Total Hip System","sku_code":"MRL-LIBERTAS-HIP","product_family":"Libertas Total Hip System","product_family_display":"Libertas Total Hip System","slug":"libertas-total-hip-system","images":[{"storage_path":"agile-ortho/products/mrl-libertas-hip/cover_2cf36a06.jpg","filename":"mrl-libertas-hip_2cf36a06.jpg","source":"brochure_cover"}],"status":"published","live_visible":true,"brochure_url":"agile-ortho/brochures/libertas-hip-system.pdf","seo_meta_title":"Libertas Total Hip System | Libertas Total Hip System Total Hip Replacement - MedDevice Pro Telangana","seo_meta_description":"Comprehensive total hip replacement system featuring femoral stems, acetabular cups, liners, and femoral heads. Designed for both cemented and cementless fix...","pack_size":"","size_variables":[],"created_at":"2026-03-26T13:45:55.431728+00:00","updated_at":"2026-03-26T14:44:34.055869+00:00","division_canonical":"Joint Replacement","division_live_original":"Joint Replacement","category":"Total Hip Replacement","material_canonical":"Titanium + Cobalt-Chromium + Ceramic","material_live_original":"Titanium + Cobalt-Chromium + Ceramic","manufacturer":"Meril Life Sciences","description_live":"Comprehensive total hip replacement system featuring femoral stems, acetabular cups, liners, and femoral heads. Designed for both cemented and cementless fixation. Multiple stem designs including fully coated (HA) and proximally coated (Ti plasma spray). Press-fit acetabular shell with provision for bone screws. Compatible with ceramic and UHMWPE bearing surfaces.","technical_specifications":{"stem_types":"Fully Coated HA, Proximally Coated Ti Plasma Spray","cup":"Press-fit with Bone Screw Provision","bearings":"Ceramic, UHMWPE","fixation":"Cemented + Cementless"},"brand":"Libertas Total Hip System","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:51:00.096877+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Modular Total Hip Arthroplasty System with Cemented and Cementless Fixation Options","proposed_clinical_display_title":"Libertas Total Hip System","proposed_clinical_subtitle":"Modular Total Hip Arthroplasty System with Cemented and Cementless Fixation Options","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T07:17:32.792360+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly describes a comprehensive total hip replacement system with modular components (stems, cups, liners, heads). The brochure description is detailed and internally consistent. However, no external verification available, brand field is empty, and manufacturer (Meril Life Sciences) cannot be independently confirmed. Multiple material combinations (Ti, CoCr, Ceramic, UHMWPE) are component-specific, not system-level defaults, so semantic_material_default set to null. System supports both cemented and cementless techniques with different coating options (HA fully coated, Ti plasma spray proximally coated). This is clearly a product_family umbrella with multiple component configurations. Marked for review due to: (1) missing brand confirmation, (2) no external source verification, (3) need to confirm manufacturer attribution to Meril Life Sciences. Clinical meaning is clear from internal evidence but requires external validation for web publication confidence.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Hip"],"proposed_semantic_brand_system":"Libertas Total Hip System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Libertas Hip Reconstruction","proposed_semantic_implant_class":"Total Hip Replacement","proposed_semantic_material_default":null,"proposed_semantic_parent_brand":"Libertas","proposed_semantic_procedure_scope":["Total Hip Arthroplasty","Primary Hip Replacement"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Total Hip Arthroplasty System","proposed_semantic_use_case_tags":["modular_system","dual_fixation_capability","cemented_option","cementless_option","press_fit_acetabular","multiple_bearing_surfaces","hydroxyapatite_coating_option","titanium_plasma_spray_option"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Hip"],"semantic_brand_system":"Libertas Total Hip System","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.048097+00:00","semantic_implant_class":"Total Hip Replacement","semantic_material_default":null,"semantic_parent_brand":"Libertas","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Total Hip Arthroplasty System"}}]
