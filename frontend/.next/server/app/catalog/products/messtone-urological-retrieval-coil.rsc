iew_required":true,"proposed_semantic_system_type":"Stone Retrieval System","proposed_semantic_use_case_tags":["stone retrieval","holmium laser compatible","urolithiasis","kidney stone removal","quick release handle","stone fragmentation"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Urinary Tract","Kidney","Ureter","Bladder"],"semantic_brand_system":"Messtone","semantic_coating_default":null,"semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.194153+00:00","semantic_implant_class":"N/A - Reusable/Single-Use Instrument","semantic_material_default":"Medical Grade Alloy","semantic_parent_brand":"Messtone","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Stone Retrieval System"}}]]}]]}],false,"$undefined","$L15","$L16"]}]]}]
