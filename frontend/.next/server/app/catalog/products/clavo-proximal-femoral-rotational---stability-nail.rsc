19:["$","$L1d",null,{"product":{"product_name":"CLAVO Proximal Femoral Rotational - Stability Nail","product_name_display":"CLAVO Proximal Femoral Rotational-Stability Nail","sku_code":"MFNT0109170","product_family":"CLAVO Proximal Femoral Nails","product_family_display":"CLAVO Proximal Femoral Nails","slug":"clavo-proximal-femoral-rotational---stability-nail","images":[{"id":"1effd94d60d9","storage_path":"agile-ortho/products/69c49fc021c25bab426785e4/cover_9ef2eee3.jpg","original_filename":"cover_Nail_CLAVO_Ti_Catalogue_Meril.pdf.jpg","content_type":"image/jpeg","size":188527,"uploaded_at":"2026-03-26T05:57:53.969421+00:00","source":"brochure_extraction","width":2339,"height":1653},{"id":"384a62f15f57","storage_path":"agile-ortho/products/69c49fc021c25bab426785e4/cover_7af6ef37.jpg","original_filename":"cover_Nail_CLAVO_Ti_Catalogue_Meril.pdf.jpg","content_type":"image/jpeg","size":188527,"uploaded_at":"2026-03-26T06:02:28.445292+00:00","source":"brochure_extraction","width":2339,"height":1653}],"status":"published","live_visible":true,"brochure_url":"agile-ortho/brochures/clavo-pfrn.pdf","seo_meta_title":"CLAVO Proximal Femoral Rotational-Stability Nail | CLAVO Proximal Femoral Nails - MedDevice Pro Telangana","seo_meta_description":"A comprehensive intramedullary nailing system designed for the treatment of various long bone fractures, bone tumors, and deformities. The system includes an...","pack_size":"Sterile","size_variables":"Diameter: 9.0-12.0mm, Length: 170-440mm","created_at":"2026-03-26T02:53:52.480209+00:00","updated_at":"2026-03-26T14:44:33.959883+00:00","division_canonical":"Trauma","division_live_original":"Trauma","category":"Proximal Femoral Nails","material_canonical":"Ti6Al7Nb","material_live_original":"Ti6Al7Nb","manufacturer":"Meril","description_live":"Proximal femoral rotational-stability nail for femur fractures with anatomical design for best fit in femur bone. Features M/L angle of 5° for easy insertion and bendable tip to reduce stress on bone.","technical_specifications":{"Proximal Femoral Rotational Stability Nail (PFRN) Range":"Diameters: 9.0mm, 10.0mm, 11.0mm, 12.0mm; Lengths: 170mm to 440mm; Material: TAN (Ti-6Al-7Nb)","Cannulated Titanium Tibial Nail (CTTN) Range":"Diameters: 8.0mm, 9.0mm, 10.0mm, 11.0mm, 12.0mm, 13.0mm; Lengths: 255mm to 450mm; Material: TAN (Ti-6Al-7Nb)","Elastic Titanium Nail (TEN) Range":"Diameters: 1.5mm, 2.0mm, 2.5mm, 3.0mm, 3.5mm, 4.0mm; Lengths: 300mm to 440mm; Material: TAV (Ti-6Al-4V)","Shaft Femur Titanium Nail Cannulated Range":"Diameters: 9.0mm, 10.0mm, 11.0mm, 12.0mm; Lengths: 340mm to 440mm; Material: TAN (ASTM-F1295-11)","Shaft Tibia Titanium Nail Cannulated Range":"Diameters: 8.0mm, 9.0mm, 10.0mm; Lengths: 280mm to 380mm; Material: TAN (ASTM-F1295-11)","Anti-Rotation Screw for PFRN":"Diameter: 12mm; Lengths: 75mm to 120mm; Material: TAN (Ti-6Al-7Nb)","4.9mm Locking Bolt, Self Tapping":"Head Dia: 8.0mm; Outer Dia: 4.9mm; Core Dia: 4.25mm; Pitch: 2.75mm; Lengths: 26mm to 100mm","3.9mm Locking Bolt Self Tapping":"Head Dia: 8.0mm; Outer Dia: 3.9mm; Core Dia: 3.25mm; Pitch: 2.3mm; Lengths: 22mm to 60mm; Material: TAV (Ti-6Al-4V)","4.0mm Locking Screw Medullary Nail":"Head Dia: 8.0mm; Outer Dia: 3.9mm; Core Dia: 3.25mm; Pitch: 1.25mm; Lengths: 18mm to 80mm; Material: TAN (Ti-6Al-7Nb)"},"brand":"CLAVO","parent_brand":"","description_shadow":"A comprehensive intramedullary nailing system designed for the treatment of various long bone fractures, bone tumors, and deformities. The system includes anatomically shaped nails for the femur and tibia, specialized locking bolts, and dedicated instrument sets to ensure smooth and trouble-free operating procedures.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"fuzzy_token","match_score":0.5,"catalog_created_at":"2026-03-27T16:50:59.825662+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Intramedullary Nail for Proximal Femur Fractures","proposed_clinical_display_title":"CLAVO Proximal Femoral Rotational-Stability Nail","proposed_clinical_subtitle":"Intramedullary Nail for Proximal Femur Fractures","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T06:00:46.671943+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Internal evidence clearly describes a proximal femoral intramedullary nail with rotational stability features. The brochure description provides sufficient clinical context: anatomical design for proximal femur fractures, 5° M/L angle for insertion, bendable tip, Ti6Al7Nb material. This is a specific implant class within the CLAVO product family. Brand extracted from context (CLAVO system by Meril). Current title lacks the CLAVO brand identifier which is critical for clinical identification. Recommended rename to include brand prefix. Review required due to missing brand in original title and to confirm CLAVO system naming convention across product family.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["proximal_femur","femoral_neck","intertrochanteric_region"],"proposed_semantic_brand_system":"CLAVO","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"CLAVO Proximal Femoral Nails","proposed_semantic_implant_class":"proximal_femoral_nail","proposed_semantic_material_default":"Ti6Al7Nb","proposed_semantic_parent_brand":"Meril","proposed_semantic_procedure_scope":["proximal_femur_fracture_fixation","intertrochanteric_fracture_fixation","pertrochanteric_fracture_fixation","subtrochanteric_fracture_fixation"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"intramedullary_nailing_system","proposed_semantic_use_case_tags":["rotational_stability","anatomical_design","bendable_tip","5_degree_ML_angle","trauma_fixation"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["proximal_femur","femoral_neck","intertrochanteric_region"],"semantic_brand_system":"CLAVO","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.516505+00:00","semantic_implant_class":"proximal_femoral_nail","semantic_material_default":"Ti6Al7Nb","semantic_parent_brand":"Meril","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"intramedullary_nailing_system","clinical_indications":["Bone fractures","Bone tumors","Deformities","Proximal femur fractures","Tibial shaft fractures","Femoral shaft fractures"],"materials_canonical":"TAN (Ti-6Al-7Nb)","features_list":["High fatigue strength","Negligible soft tissue damage","Proper fixation for rotational stability","Self-tapping locking bolts","Comprehensive instrumentation including remote aiming racks and specialized reamers","Anatomically contoured nail designs"],"brochure_intelligence_updated":true}}]
