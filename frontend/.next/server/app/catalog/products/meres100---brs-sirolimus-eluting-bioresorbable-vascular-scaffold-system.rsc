sis prevention","technical_specifications":{"scaffold_material":"BioResorbable PLLA (Poly L-lactide)","strut_thickness":"100 µm","drug":"Sirolimus","drug_dose":"1.25 µg/mm²","polymer":"BioResorbable PDLLA (Poly D, L-lactide)","ro_markers":"Platinum tri-axial markers","delivery_system":"Rapid Exchange","nominal_pressure":"9 atm","rated_burst_pressure":"16 atm","balloon_overhang":"< 0.5 mm","shaft_diameter":"Proximal 1.95 F / Distal 2.7 F","catheter_length":"140 cm","guide_catheter_compatibility":"6 F (Min. I.D 0.070\" / 1.8 mm)","max_guidewire":"0.014\" (0.36 mm)","crossing_profile":"1.2 mm average for 3.00 mm diameter"},"brand":"MeRes100","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.444,"catalog_created_at":"2026-03-27T16:50:59.859473+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"100 μm strut thickness, PLLA scaffold with PDLLA drug coating, platinum markers","proposed_clinical_display_title":"MeRes100 BRS Sirolimus-Eluting Bioresorbable Vascular Scaffold","proposed_clinical_subtitle":"100 μm strut thickness, PLLA scaffold with PDLLA drug coating, platinum markers","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T06:12:44.169568+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly identifies this as a bioresorbable vascular scaffold (BRS) product family from Meril Life Sciences. The MeRes100 designation appears to indicate 100 μm strut thickness as a key differentiator. All technical specifications are internally consistent: PLLA scaffold material, sirolimus drug (1.25 μg/mm²), PDLLA drug-eluting polymer, platinum tri-axial radiopaque markers, rapid exchange delivery system. The product is positioned in coronary stent category which is accurate for BRS devices. No external sources available for verification, but internal evidence is comprehensive and clinically coherent. Review recommended solely due to brand_missing flag and to verify if MeRes is confirmed manufacturer brand vs. product line naming convention, and to confirm this is not a variant within a broader MeRes family that should be consolidated. No conflicts detected in technical specifications or clinical positioning.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Coronary Arteries"],"proposed_semantic_brand_system":"MeRes100","proposed_semantic_coating_default":"Sirolimus-eluting PDLLA (Poly D,L-lactide)","proposed_semantic_confidence":0.92,"proposed_semantic_family_group":"MeRes Bioresorbable Scaffold Platform","proposed_semantic_implant_class":"Coronary Bioresorbable Scaffold","proposed_semantic_material_default":"PLLA (Poly L-lactide)","proposed_semantic_parent_brand":"MeRes","proposed_semantic_procedure_scope":["Percutaneous Coronary Intervention","Coronary Angioplasty"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Bioresorbable Vascular Scaffold System","proposed_semantic_use_case_tags":["coronary revascularization","restenosis prevention","drug-eluting bioresorbable scaffold","temporary vessel support","vessel healing restoration"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Coronary Arteries"],"semantic_brand_system":"MeRes100","semantic_coating_default":"Sirolimus-eluting PDLLA (Poly D,L-lactide)","semantic_confidence":0.92,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:48.965132+00:00","semantic_implant_class":"Coronary Bioresorbable Scaffold","semantic_material_default":"PLLA (Poly L-lactide)","semantic_parent_brand":"MeRes","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_INTERNALLY_VERIFIED"],"semantic_system_type":"Bioresorbable Vascular Scaffold System"}}]
