18:["$","$L1b",null,{"product":{"product_name":"ARMAR 2.4mm Locking Plate System Instrument Set","product_name_display":"KET 2.4mm Locking Plate System Instrument Set","sku_code":"MRL-ARM-INS01","product_family":"ARMAR 2.4mm Locking Plate System Instrument Set","product_family_display":"ARMAR 2.4mm Locking Plate System Instrument Set","slug":"armar-2.4mm-locking-plate-system-instrument-set","images":[{"id":"prop_69c2d2d","storage_path":"agile-ortho/products/69c2d2d07171238d2edca5ad/cover_93e430f9.jpg","original_filename":"cover_LBL_Plate_Chart_Meril.pdf.jpg","content_type":"image/jpeg","size":572912,"uploaded_at":"2026-03-26T05:56:24.795886+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"KET 2.4mm Locking Plate System Instrument Set | KET Surgical Instruments - MedDevice Pro Telangana","seo_meta_description":"ARMAR 2.4mm Locking Plate System Instrument Set offers comprehensive surgical instrumentation for trauma procedures with precision-engineered stainless steel...","pack_size":"Set with Case","size_variables":["Complete Set"],"created_at":"2026-03-24T18:07:12.128463+00:00","updated_at":"2026-03-26T14:44:33.834156+00:00","division_canonical":"Instruments","division_live_original":"Instruments","category":"Surgical Instruments","material_canonical":"Stainless Steel (Surgical Grade)","material_live_original":"Stainless Steel","manufacturer":"Meril Life Sciences","description_live":"ARMAR 2.4mm Locking Plate System Instrument Set offers comprehensive surgical instrumentation for trauma procedures with precision-engineered stainless steel construction. This complete set includes 1.8mm and 2.0mm drill bits, torque limiter, depth gauge, and drill guides for optimal surgical outcomes. Designed for seamless compatibility with the 2.4mm ARMAR system, ensuring accurate plate fixation and bone stabilization. Essential instrumentation for orthopedic trauma surgeons requiring reliable, sterile surgical tools.","technical_specifications":{"drill_bits":"1.8mm and 2.0mm","includes":"Torque limiter, depth gauge, drill guides","compatibility":"2.4mm ARMAR system"},"brand":"KET","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.528078+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Comprehensive Surgical Instrumentation for Small Fragment Trauma Fixation","proposed_clinical_display_title":"KET 2.4mm Locking Plate System Instrument Set","proposed_clinical_subtitle":"Comprehensive Surgical Instrumentation for Small Fragment Trauma Fixation","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:19:37.104709+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"External evidence from Meril manufacturer sources (tier1 and tier4) confirms this is the KET 2.4mm Locking Plate System Instrument Set, not 'ARMAR' as listed in internal data. The product ID contains 'armar' but all external evidence consistently identifies this as part of Meril's KET (not ARMAR) trauma fixation system. Part number MT-INDR24001 confirmed from source_2. The instrument set includes drill bits (1.8mm, 2.0mm), torque limiter, depth gauge, and drill guides for 2.4mm locking plate application in small fragment trauma fixation. Brand correction from ARMAR to KET required. Material and specifications are accurately documented. Anatomy scope inferred from 2.4mm sizing which is standard for hand, wrist, foot, ankle, and small bone fragment procedures. Review recommended due to brand name discrepancy between internal naming (ARMAR) and verified manufacturer designation (KET).","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Hand","Wrist","Foot","Ankle","Small Bone Fragments"],"proposed_semantic_brand_system":"KET","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.92,"proposed_semantic_family_group":"KET 2.4mm Locking Plate System","proposed_semantic_implant_class":"Surgical Instrument Set","proposed_semantic_material_default":"Stainless Steel (Surgical Grade)","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Trauma Fixation","Fracture Fixation","Osteosynthesis","Small Fragment Plating"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Locking Plate System Instrumentation","proposed_semantic_use_case_tags":["trauma surgery","small fragment fixation","locking plate application","precision drilling","plate fixation instrumentation"],"proposed_web_verification_status":"externally_enriched","semantic_anatomy_scope":["Hand","Wrist","Foot","Ankle","Small Bone Fragments"],"semantic_brand_system":"KET","semantic_coating_default":null,"semantic_confidence":0.92,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.448768+00:00","semantic_implant_class":"Surgical Instrument Set","semantic_material_default":"Stainless Steel (Surgical Grade)","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_ENRICHED"],"semantic_system_type":"Locking Plate System Instrumentation"}}]
