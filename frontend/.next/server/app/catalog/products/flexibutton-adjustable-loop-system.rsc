15:["$","$L18",null,{"product":{"product_name":"FLEXIBUTTON Adjustable Loop System","product_name_display":"FLEXIBUTTON Adjustable Loop System","sku_code":"MA-KZT00040","product_family":"FLEXIBUTTON Adjustable Loop System","product_family_display":"FLEXIBUTTON Adjustable Loop System","slug":"flexibutton-adjustable-loop-system","images":[{"storage_path":"agile-ortho/products/spm-brochure/cover_c84c31b4.jpg","filename":"spm_cover_c84c31b4.jpg","source":"brochure_cover"}],"status":"published","live_visible":true,"brochure_url":"agile-ortho/brochures/sports-medicine-catalog.pdf","seo_meta_title":"FLEXIBUTTON Adjustable Loop System | FLEXIBUTTON Knee Arthroscopy - MedDevice Pro Telangana","seo_meta_description":"Adjustable loop system for ACL and PCL cruciate ligament reconstruction. Biocompatible titanium button with USP #5 UHMWPE pull rope sutures. Easy flipping an...","pack_size":"","size_variables":["70mm","110mm"],"created_at":"2026-03-26T13:21:05.194822+00:00","updated_at":"2026-03-26T14:44:34.047620+00:00","division_canonical":"Sports Medicine","division_live_original":"Sports Medicine","category":"Knee Arthroscopy","material_canonical":"Titanium + UHMWPE","material_live_original":"Titanium + UHMWPE","manufacturer":"Meril Life Sciences","description_live":"Adjustable loop system for ACL and PCL cruciate ligament reconstruction. Biocompatible titanium button with USP #5 UHMWPE pull rope sutures. Easy flipping and pulling mechanism. Graft support frame design increases surface contact.","technical_specifications":{"button":"Titanium Ti-6Al-4V ELI","suture":"USP #5 UHMWPE","type":"Adjustable Loop","length":"70mm","design":"Knitrope Plus Upper Side Pull Out"},"brand":"FLEXIBUTTON","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:51:00.068181+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"FLEXIBUTTON Adjustable Loop System","proposed_clinical_subtitle":"Adjustable Cortical Fixation for ACL/PCL Reconstruction","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T07:10:50.765341+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal brochure provides comprehensive clinical description. This is a cortical suspensory fixation device used in ACL/PCL reconstruction procedures. The system consists of a titanium button (Ti-6Al-4V ELI) with UHMWPE sutures forming an adjustable loop mechanism. Key features described include easy flipping/pulling mechanism and graft support frame design for increased surface contact. The 'adjustable loop' mechanism allows intraoperative tension adjustment. Division placement in Sports Medicine/Knee Arthroscopy aligns with ACL/PCL reconstruction use case. Product specifications (70mm length, Knitrope Plus Upper Side Pull Out design, USP #5 UHMWPE suture) are consistent with femoral/tibial cortical fixation applications. FLEXIBUTTON functions as both brand and product family name. No external verification needed as internal evidence is clinically coherent and complete. Brand missing flag is resolved - FLEXIBUTTON itself is the brand. No conflicts detected.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Knee","Femur","Tibia"],"proposed_semantic_brand_system":"FLEXIBUTTON","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Knee Ligament Reconstruction Fixation","proposed_semantic_implant_class":"Adjustable Loop Button","proposed_semantic_material_default":"Titanium Ti-6Al-4V ELI","proposed_semantic_parent_brand":"FLEXIBUTTON","proposed_semantic_procedure_scope":["ACL Reconstruction","PCL Reconstruction","Cruciate Ligament Reconstruction"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Adjustable Loop Cortical Fixation System","proposed_semantic_use_case_tags":["Adjustable Fixation","Cortical Fixation","Graft Fixation","ACL","PCL","Suspensory Fixation"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Knee","Femur","Tibia"],"semantic_brand_system":"FLEXIBUTTON","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.541122+00:00","semantic_implant_class":"Adjustable Loop Button","semantic_material_default":"Titanium Ti-6Al-4V ELI","semantic_parent_brand":"FLEXIBUTTON","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Adjustable Loop Cortical Fixation System"}}]
