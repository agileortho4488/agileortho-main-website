7:["$","div",null,{"className":"min-h-screen bg-[#0A0A0A] text-white","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org/\",\"@type\":\"Product\",\"name\":\"Inviro Surface Cleaner/Disinfectant\",\"description\":\"Inviro Surface Cleaner/Disinfectant features 7% didecyldimethyl ammonium chloride, a 4th generation QAC formulation for superior pathogen elimination in healthcare environments. This aldehyde-free concentrate provides broad-spectrum antimicrobial efficacy against bacteria, viruses, and fungi on medical equipment and surfaces. Designed for infection prevention protocols, it offers rapid disinfection with excellent material compatibility. Ideal for operating theaters, ICUs, and patient care areas requiring high-level surface decontamination standards.\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Meril\"},\"category\":\"Surface Disinfectants\",\"manufacturer\":{\"@type\":\"Organization\",\"name\":\"Meril Life Sciences\"},\"offers\":{\"@type\":\"AggregateOffer\",\"offerCount\":\"1\",\"lowPrice\":\"0\",\"priceCurrency\":\"INR\",\"availability\":\"https://schema.org/InStock\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://agileortho.in\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Catalog\",\"item\":\"https://agileortho.in/catalog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Infection Prevention\",\"item\":\"https://agileortho.in/catalog/infection-prevention\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Inviro Surface Cleaner/Disinfectant\",\"item\":\"https://agileortho.in/catalog/products/inviro-surface-cleaner-disinfectant\"}]}"}}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24","children":[["$","nav",null,{"className":