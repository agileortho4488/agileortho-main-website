achian Tube Balloon Dilatation System","sku_code":"MYCS","product_family":"MYCS Eustachian Tube Balloon Dilatation System","product_family_display":"MYCS Eustachian Tube Balloon Dilatation System","slug":"mycs-eustachian-tube-balloon-dilatation-system","images":[{"id":"fb41815d14c6","storage_path":"agile-ortho/products/69c17bd504841ec9248cfad3/cover_217c3167.jpg","original_filename":"cover_MESIRE Brochure.pdf.jpg","content_type":"image/jpeg","size":393249,"uploaded_at":"2026-03-26T05:56:49.679038+00:00","source":"division_fallback","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MYCS Eustachian Tube Balloon Dilatation System | Meril ENT - Agile Ortho Telangana","seo_meta_description":"Eustachian tube balloon dilatation system","pack_size":null,"size_variables":null,"created_at":"2026-03-26T02:42:48.658906+00:00","updated_at":"2026-03-26T14:44:33.954080+00:00","division_canonical":"ENT","division_live_original":"ENT","category":"Balloon Catheters","material_canonical":null,"material_live_original":null,"manufacturer":null,"description_live":"Eustachian tube balloon dilatation system","technical_specifications":null,"brand":"MYCS","parent_brand":"Meril","description_shadow":"Eustachian tube balloon dilatation system with non-compliant Pebax balloons, latch handle, guide catheters. Balloon diameters 5/6/7mm, lengths 14/17mm.","division_shadow_original":"ENT","shadow_product_id":"890588e01aacf273","shadow_source_files":["ENT All Product Portfolio .pdf"],"shadow_source_pages":["15-16"],"shadow_sku_count":14,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"family_brand_division","match_score":1,"catalog_created_at":"2026-03-27T16:50:59.807133+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"MYCS by Meril","proposed_clinical_display_title":"MYCS Eustachian Tube Balloon Dilatation System","proposed_clinical_subtitle":"Non-Compliant Pebax Balloon Catheter for Eustachian Tube Dilatation","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:56:06.464875+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence is comprehensive and clinically coherent. This is a well-defined product family for Eustachian tube balloon dilatation with clear specifications: non-compliant Pebax balloon material, three diameter options (5/6/7mm), two length options (14/17mm), includes latch handle and guide catheters. The SKU pattern (MEB followed by diameter and length codes) confirms systematic product variants within a single family. Eustachian tube balloon dilatation is an established ENT procedure for treating Eustachian tube dysfunction. The MYCS brand appears to be the manufacturer/brand system name. No external verification needed as internal evidence is sufficient and unambiguous. Classification as product_family is appropriate given the multiple size variants sharing common design platform and indication.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Eustachian Tube","Middle Ear","Nasopharynx"],"proposed_semantic_brand_system":"MYCS","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"ENT Balloon Dilatation Systems","proposed_semantic_implant_class":"Balloon Catheter","proposed_semantic_material_default":"Pebax","proposed_semantic_parent_brand":"MYCS","proposed_semantic_procedure_scope":["Eustachian Tube Balloon Dilatation","Eustachian Tube Dilation","Treatment of Eustachian Tube Dysfunction"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Balloon Dilatation System","proposed_semantic_use_case_tags":["Eustachian Tube Dysfunction","Chronic Otitis Media with Effusion","Barotitis","ETD Treatment","Minimally Invasive ENT"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Eustachian Tube","Middle Ear","Nasopharynx"],"semantic_brand_system":"MYCS","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.514430+00:00","semantic_implant_class":"Balloon Catheter","semantic_material_default":"Pebax","semantic_parent_brand":"MYCS","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Balloon Dilatation System"}}]]}]]}],false,"$undefined","$L16","$L17"]}]]}]
