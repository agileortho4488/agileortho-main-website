HOOK Soft Anchor System","proposed_semantic_implant_class":"Suture Anchor","proposed_semantic_material_default":"Ultra-High Molecular Weight Polyethylene (UHMWPE)","proposed_semantic_parent_brand":"FILAHOOK","proposed_semantic_procedure_scope":["Shoulder Arthroscopy","Soft Tissue Repair","Rotator Cuff Repair","Labral Repair","Capsular Repair"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"All-Suture Anchor System","proposed_semantic_use_case_tags":["all-suture anchor","minimally invasive","small pilot hole","curved sleeve compatible","soft tissue fixation"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Shoulder"],"semantic_brand_system":"FILAHOOK Soft Anchor System","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.033821+00:00","semantic_implant_class":"Suture Anchor","semantic_material_default":"Ultra-High Molecular Weight Polyethylene (UHMWPE)","semantic_parent_brand":"FILAHOOK","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"All-Suture Anchor System"}}]
