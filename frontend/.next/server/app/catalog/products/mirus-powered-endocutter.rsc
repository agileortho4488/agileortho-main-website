a/cover_b7bd3361.jpg","original_filename":"cover_Endo P1 Product Range.pdf.jpg","content_type":"image/jpeg","size":718573,"uploaded_at":"2026-03-26T05:55:53.511695+00:00","source":"brochure_extraction","width":4410,"height":1750},{"id":"c7f40e8d2445","storage_path":"agile-ortho/products/69c17bd504841ec9248cfada/cover_1108df2c.jpg","original_filename":"cover_Endo P1 Product Range.pdf.jpg","content_type":"image/jpeg","size":718573,"uploaded_at":"2026-03-26T06:00:54.775079+00:00","source":"brochure_extraction","width":4410,"height":1750}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"Mirus Powered Endoscopic Linear Cutter | Mirus Staplers - MedDevice Pro Telangana","seo_meta_description":"Powered endoscopic linear cutting stapler for precise tissue transection and stapling in minimally invasive procedures. Consistent staple formation.","pack_size":"","size_variables":[],"created_at":"2026-03-23T17:43:49.607823+00:00","updated_at":"2026-03-26T14:44:33.822538+00:00","division_canonical":"Endo Surgery","division_live_original":"Endo-surgical","category":"Staplers","material_canonical":"Surgical Steel + Polymer","material_live_original":"Surgical Steel + Polymer","manufacturer":"Meril Life Sciences","description_live":"Powered endoscopic linear cutting stapler for precise tissue transection and stapling in minimally invasive procedures. Consistent staple formation.","technical_specifications":{"type":"Powered Linear Endocutter","stapling":"Consistent Formation","approach":"Minimally Invasive"},"brand":"Mirus","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_b