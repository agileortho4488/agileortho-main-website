16:["$","$L19",null,{"product":{"product_name":"MESIRE Guide Sinus Guide Catheter 110°","product_name_display":"MESIRE Guide Sinus Guide Catheter 110°","sku_code":"MSG110","product_family":"MESIRE Sinus Guide Catheters","product_family_display":"MESIRE Sinus Guide Catheters","slug":"mesire-guide-sinus-guide-catheter-110","images":[{"id":"prop_69c3e6b","storage_path":"agile-ortho/products/69c17bd504841ec9248cfad3/cover_217c3167.jpg","original_filename":"cover_MESIRE Brochure.pdf.jpg","content_type":"image/jpeg","size":393249,"uploaded_at":"2026-03-26T05:56:49.679038+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MESIRE Guide Sinus Guide Catheter 110° | MESIRE Balloon Catheters - MedDevice Pro Telangana","seo_meta_description":"Complete sinus balloon dilation system with non-compliant balloons, guide catheters, light wire, and sinus kits for frontal and maxillary procedures.","pack_size":"Single use sterile","size_variables":["110° angle"],"created_at":"2026-03-25T13:44:27.836544+00:00","updated_at":"2026-03-26T14:44:33.878149+00:00","division_canonical":"ENT","division_live_original":"ENT","category":"Balloon Catheters","material_canonical":"Medical grade polymer with silicon outer layer","material_live_original":"Medical grade polymer with silicon outer layer","manufacturer":"Meril Life Sciences","description_live":"Guide catheter with 110° distal angle designed for targeted navigation of balloon catheter into sinus ostium. Features soft atraumatic tip to prevent tissue trauma during insertion.","technical_specifications":{"distal_angle":"110°","tip_design":"Soft atraumatic tip","outer_layer":"Silicon","shaft":"Rigid shaft with transparent curved tip"},"brand":"MESIRE","parent_brand":"Meril","description_shadow":"Complete sinus balloon dilation system with non-compliant balloons, guide catheters, light wire, and sinus kits for frontal and maxillary procedures.","division_shadow_original":"ENT","shadow_product_id":"435da92085bc0c16","shadow_source_files":["ENT All Product Portfolio .pdf"],"shadow_source_pages":["13"],"shadow_sku_count":19,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"exact_sku_link","match_score":1,"catalog_created_at":"2026-03-27T16:50:59.628142+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"MESIRE by Meril","proposed_clinical_display_title":"MESIRE Sinus Guide Catheter 110°","proposed_clinical_subtitle":"Guide catheter with 110° distal angle for balloon sinus dilation procedures","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:08:55.718766+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"This is a guide catheter component within the MESIRE Sinus Balloon Dilation System. Internal evidence clearly identifies it as a guide catheter with 110° distal angle used for navigating balloon catheters during sinus dilation procedures. External source_2 confirms multiple angle options (0°, 30°, 70°, 90°, 110°) and their purpose for targeted navigation of MESIRE balloon catheters. This is an accessory/instrument, not an implant. The product family 'MESIRE Sinus Guide Catheters' is appropriate as this represents one angle variant within a family of guide catheters. Material specification (medical grade polymer with silicone outer layer) is consistent with catheter construction. The 110° angle is a specific navigation variant for accessing different sinus anatomy. Current title and classification are accurate and well-supported by both internal and external evidence.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Paranasal sinuses","Frontal sinus","Maxillary sinus","Sinus ostia"],"proposed_semantic_brand_system":"MESIRE Sinus Balloon Dilation System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MESIRE Sinus Guide Catheters","proposed_semantic_implant_class":"N/A - Accessory device","proposed_semantic_material_default":"Medical grade polymer with silicone outer layer","proposed_semantic_parent_brand":"MESIRE","proposed_semantic_procedure_scope":["Balloon sinus dilation","Sinus ostial dilation","Functional endoscopic sinus surgery"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Balloon sinus dilation system","proposed_semantic_use_case_tags":["Guide catheter","Balloon catheter navigation","ENT endoscopy","Minimally invasive sinus surgery"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Paranasal sinuses","Frontal sinus","Maxillary sinus","Sinus ostia"],"semantic_brand_system":"MESIRE Sinus Balloon Dilation System","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.474797+00:00","semantic_implant_class":"N/A - Accessory device","semantic_material_default":"Medical grade polymer with silicone outer layer","semantic_parent_brand":"MESIRE","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Balloon sinus dilation system"}}]
