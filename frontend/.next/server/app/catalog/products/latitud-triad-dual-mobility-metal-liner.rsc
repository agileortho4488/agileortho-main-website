":"Dual articulation","inner_bearing":"Polyethylene insert","outer_bearing":"Metal-on-polyethylene","stability_feature":"Enhanced range of motion"},"brand":"LATITUD TRIAD","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.758417+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Dual Mobility Acetabular Liner with Polyethylene Insert","proposed_clinical_display_title":"LATITUD TRIAD Dual Mobility Metal Liner","proposed_clinical_subtitle":"Dual Mobility Acetabular Liner with Polyethylene Insert","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:45:22.487502+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence clearly describes a dual mobility acetabular liner system with two articulation surfaces (inner polyethylene insert with femoral head, outer metal shell within acetabular cup). The product is correctly categorized as a Hip Acetabular Component. However, brand is missing and no external verification is available. The brochure description is internally consistent and clinically coherent - dual mobility systems are established technology for reducing dislocation risk in hip arthroplasty. The TRIAD designation appears to be a specific product line within the LATITUD brand family. Confidence is high based on internal evidence alone (0.85), but review is recommended due to missing brand confirmation and inability to externally verify the LATITUD TRIAD system exists as described. The material classification (metal alloy with polyethylene) is standard for dual mobility liners. No conflicts detected, but external verification would strengthen confidence to >0.95.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Hip","Acetabulum"],"proposed_semantic_brand_system":"LATITUD TRIAD","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"LATITUD TRIAD Dual Mobility System","proposed_semantic_implant_class":"Acetabular Liner","proposed_semantic_material_default":"Metal alloy with polyethylene insert","proposed_semantic_parent_brand":"LATITUD","proposed_semantic_procedure_scope":["Total Hip Arthroplasty","Hip Revision Surgery"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Dual Mobility Hip System","proposed_semantic_use_case_tags":["Dual mobility","Dislocation prevention","Enhanced stability","Dual articulation","Acetabular reconstruction"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Hip","Acetabulum"],"semantic_brand_system":"LATITUD TRIAD","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:48.934883+00:00","semantic_implant_class":"Acetabular Liner","semantic_material_default":"Metal alloy with polyethylene insert","semantic_parent_brand":"LATITUD","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Dual Mobility Hip System"}}]]}]]}],false,"$undefined","$L16","$L17"]}]]}]
