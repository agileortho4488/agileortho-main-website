16:["$","$L19",null,{"product":{"product_name":"FERENCE-TI Titanium Interference Screw","product_name_display":"FERENCE-TI Titanium Interference Screw","sku_code":"MA-KIT70025","product_family":"FERENCE-TI Titanium Interference Screw","product_family_display":"FERENCE-TI Titanium Interference Screw","slug":"ference-ti-titanium-interference-screw","images":[{"storage_path":"agile-ortho/products/spm-brochure/cover_c84c31b4.jpg","filename":"spm_cover_c84c31b4.jpg","source":"brochure_cover"}],"status":"published","live_visible":true,"brochure_url":"agile-ortho/brochures/sports-medicine-catalog.pdf","seo_meta_title":"FERENCE-TI Titanium Interference Screw | FERENCE-TI Knee Arthroscopy - MedDevice Pro Telangana","seo_meta_description":"Titanium interference screw for ACL, PCL, BTB, and tenodesis repairs. Ti-6Al-4V ELI construction. Fully threaded blunt-tip prevents graft laceration. Polishe...","pack_size":"","size_variables":["5x20mm","5x25mm","6x20mm","7x25mm","7x30mm","8x25mm","8x30mm","9x25mm","9x30mm","10x25mm","10x30mm","11x25mm","11x30mm","12x30mm"],"created_at":"2026-03-26T13:21:05.197326+00:00","updated_at":"2026-03-26T14:44:34.049432+00:00","division_canonical":"Sports Medicine","division_live_original":"Sports Medicine","category":"Knee Arthroscopy","material_canonical":"Titanium Alloy (Ti-6Al-4V ELI)","material_live_original":"Titanium Ti-6Al-4V ELI","manufacturer":"Meril Life Sciences","description_live":"Titanium interference screw for ACL, PCL, BTB, and tenodesis repairs. Ti-6Al-4V ELI construction. Fully threaded blunt-tip prevents graft laceration. Polished radiused threads for maximum graft protection. Standard 4.5mm hex. Cannulated for guide wire placement.","technical_specifications":{"material":"Ti-6Al-4V ELI Titanium","design":"Fully Threaded Blunt-Tip","hex":"4.5mm","cannulated":true},"brand":"FERENCE-TI","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"