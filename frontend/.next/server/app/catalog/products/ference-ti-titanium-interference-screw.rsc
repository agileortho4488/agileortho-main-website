ep_as_is","proposed_semantic_anatomy_scope":["Knee"],"proposed_semantic_brand_system":"FERENCE-TI","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.92,"proposed_semantic_family_group":"Soft Tissue Fixation","proposed_semantic_implant_class":"Interference Screw","proposed_semantic_material_default":"Titanium Alloy (Ti-6Al-4V ELI)","proposed_semantic_parent_brand":"FERENCE","proposed_semantic_procedure_scope":["ACL Reconstruction","PCL Reconstruction","Bone-Tendon-Bone (BTB) Graft Fixation","Tenodesis"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Interference Screw Fixation System","proposed_semantic_use_case_tags":["ligament reconstruction","graft fixation","arthroscopic surgery","cannulated design","blunt tip","graft protection"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Knee"],"semantic_brand_system":"FERENCE-TI","semantic_coating_default":null,"semantic_confidence":0.92,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.541583+00:00","semantic_implant_class":"Interference Screw","semantic_material_default":"Titanium Alloy (Ti-6Al-4V ELI)","semantic_parent_brand":"FERENCE","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Interference Screw Fixation System"}}]
