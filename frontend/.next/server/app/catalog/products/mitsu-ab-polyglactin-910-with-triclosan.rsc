17:["$","$L1a",null,{"product":{"product_name":"MITSU AB Polyglactin 910 with Triclosan","product_name_display":"MITSU AB Polyglactin 910 with Triclosan","sku_code":"PGT01-2347NE","product_family":"MITSU AB Polyglactin 910 Sutures","product_family_display":"MITSU AB Polyglactin 910 Sutures","slug":"mitsu-ab-polyglactin-910-with-triclosan","images":[{"id":"prop_69c4b7f","storage_path":"agile-ortho/products/69c17bd504841ec9248cfad8/cover_5271ff08.jpg","original_filename":"cover_Suture P1 product brochures.pdf.jpg","content_type":"image/jpeg","size":243167,"uploaded_at":"2026-03-26T05:58:31.844080+00:00","source":"family_propagation","width":1166,"height":1654}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MITSU AB Polyglactin 910 with Triclosan | MITSU AB Sutures - MedDevice Pro Telangana","seo_meta_description":"Synthetic absorbable braided coated polyglactin 910 with triclosan, violet colored, 90cm length","pack_size":"12 foils per box","size_variables":"Size 1, 40mm needle","created_at":"2026-03-26T04:37:06.111522+00:00","updated_at":"2026-03-26T14:44:33.994255+00:00","division_canonical":"Endo Surgery","division_live_original":"Endo-surgical","category":"Sutures","material_canonical":"Polyglactin 910 with Triclosan","material_live_original":"Polyglactin 910 with Triclosan","manufacturer":"Meril Life Sciences","description_live":"Synthetic absorbable braided coated polyglactin 910 with triclosan, violet colored, 90cm length","technical_specifications":{"specification":"Size 1, 1/2 Circle Round Body needle, 40mm dimension, enhanced needle geometry with ultra high-strength stainless steel"},"brand":"MITSU AB","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.922313+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Synthetic absorbable braided sutures with triclosan coating","proposed_clinical_display_title":"MITSU AB Polyglactin 910 Antibacterial Sutures","proposed_clinical_subtitle":"Synthetic absorbable braided sutures with triclosan coating","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T06:30:20.185769+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"This is a polyglactin 910 absorbable suture line with triclosan antibacterial coating, manufactured by Meril Life Sciences. The 'MITSU AB' designation clearly indicates an antibacterial (AB) variant within the MITSU suture family. Polyglactin 910 is a well-established copolymer material (90% glycolide, 10% L-lactide) used in absorbable sutures, comparable to Vicryl. Triclosan coating provides antibacterial properties. The brochure confirms synthetic absorbable braided construction with violet coloring and 90cm length. Material and coating classifications are verified from internal evidence. However, brand ownership is ambiguous (no brand field populated), manufacturer attribution to Meril needs verification, and external market presence cannot be confirmed without sources. Recommended for review to: (1) verify Meril as manufacturer, (2) confirm MITSU brand ownership, (3) validate market positioning vs. reference products like Vicryl Plus.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["General Soft Tissue"],"proposed_semantic_brand_system":"MITSU AB","proposed_semantic_coating_default":"Triclosan","proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"Absorbable Synthetic Sutures","proposed_semantic_implant_class":"Absorbable Synthetic Suture","proposed_semantic_material_default":"Polyglactin 910","proposed_semantic_parent_brand":"MITSU","proposed_semantic_procedure_scope":["General Surgery","Gynecological Surgery","Ophthalmic Surgery","Plastic Surgery"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Antibacterial Absorbable Suture Line","proposed_semantic_use_case_tags":["absorbable","synthetic","braided","antibacterial","coated","violet","triclosan-coated"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["General Soft Tissue"],"semantic_brand_system":"MITSU AB","semantic_coating_default":"Triclosan","semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.183827+00:00","semantic_implant_class":"Absorbable Synthetic Suture","semantic_material_default":"Polyglactin 910","semantic_parent_brand":"MITSU","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Antibacterial Absorbable Suture Line"}}]
