12:T44b,{"@context":"https://schema.org/","@type":"Product","name":"MyNox Fabric Disinfectant","description":"MyNox Fabric Disinfectant is a hospital-grade antimicrobial solution specifically formulated for comprehensive disinfection of medical fabrics, linens, and textile materials in healthcare facilities. This 500ml concentrated disinfectant effectively eliminates pathogenic microorganisms including bacteria, viruses, and fungi from hospital bedding, curtains, and patient garments. The advanced formulation ensures deep penetration into fabric fibers while maintaining textile integrity, making it ideal for infection control protocols in ICUs, operation theaters, and patient wards. Compliant with hospital safety standards, MyNox provides reliable fabric sanitization to reduce healthcare-associated infection risks.","brand":{"@type":"Brand","name":"Meril"},"category":"Surface Disinfectants","manufacturer":{"@type":"Organization","name":"Meril Life Sciences"},"offers":{"@type":"AggregateOffer","offerCount":"1","lowPrice":"0","priceCurrency":"INR","availability":"https://schema.org/InStock"}}7:["$","div",null,{"className":"min-h-screen bg-[#0A0A0A] text-white","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$12"}}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24","children":[["$","nav",null,{"className":"flex mb-10 text-sm text-muted-foreground","aria-label":"Breadcrumb","children":[["$","$L13",null,{"href":"/catalog","className":"hover:text-primary transition-colors","children":"Catalog"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","$L13",null,{"href":"/catalog/infection-prevention","className":"hover:text-primary transition-colors","children":"Infection Prevention"}],["$","span",null,{"className":"mx-2","children":"/"}],["$","span",null,{"className":"text-white truncate max-w-[200px]","children":"MyNox Fabric Disinfectant"}]]}],["$","div",null,{"className":"grid gri