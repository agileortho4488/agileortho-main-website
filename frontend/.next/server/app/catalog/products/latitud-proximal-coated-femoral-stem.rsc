w":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:51:00.095937+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Cementless Double-Taper Hip Stem with Proximal Titanium Plasma Spray Coating","proposed_clinical_display_title":"Latitud Proximal Coated Femoral Stem","proposed_clinical_subtitle":"Cementless Double-Taper Hip Stem with Proximal Titanium Plasma Spray Coating","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T07:17:20.140998+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"Internal evidence is comprehensive and clinically coherent. The brochure description provides clear technical specifications: proximally coated Ti-6Al-4V femoral stem with titanium plasma spray coating, double-taper trapezoidal design with metaphyseal flare, designed for cementless biological fixation. Multiple size options with 125° and 135° CCD angles indicate this is a product family rather than a single SKU. No external verification available, but internal evidence is sufficient for semantic classification. Brand name 'Latitud' is present in product name but not explicitly stated as brand field. Division 'Joint Replacement' and category 'Hip Stems' align with technical description. Current classification is accurate and confirmed. Confidence set to 0.85 due to lack of external verification and missing explicit brand field, but clinical meaning is unambiguous. Recommend review only to confirm brand assignment and verify manufacturer (Meril Life Sciences) association with Latitud system.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Hip","Proximal Femur"],"proposed_semantic_brand_system":"Latitud","proposed_semantic_coating_default":"Titanium Plasma Spray (Proximal)","proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Latitud Femoral Stems","proposed_semantic_implant_class":"Cementless Femoral Stem","proposed_semantic_material_default":"Ti-6Al-4V Titanium Alloy","proposed_semantic_parent_brand":"Latitud Hip System","proposed_semantic_procedure_scope":["Total Hip Arthroplasty","Primary Hip Replacement","Minimally Invasive Hip Arthroplasty"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Primary Total Hip Arthroplasty System","proposed_semantic_use_case_tags":["cementless fixation","biological fixation","press-fit","double-taper design","metaphyseal loading","rotational stability","minimally invasive compatible","proximal coating"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Hip","Proximal Femur"],"semantic_brand_system":"Latitud","semantic_coating_default":"Titanium Plasma Spray (Proximal)","semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.047288+00:00","semantic_implant_class":"Cementless Femoral Stem","semantic_material_default":"Ti-6Al-4V Titanium Alloy","semantic_parent_brand":"Latitud Hip System","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_INTERNALLY_VERIFIED"],"semantic_system_type":"Primary Total Hip Arthroplasty System"}}]
