16:["$","$L19",null,{"product":{"product_name":"MERILISA HIV Gen 4","product_name_display":"MERILISA HIV Gen 4 ELISA Kit","sku_code":"MRL-DIA-002","product_family":"MERILISA HIV Gen 4","product_family_display":"Merilisa HIV Gen 4","slug":"merilisa-hiv-gen-4","images":[{"id":"prop_69c3dee","storage_path":"agile-ortho/products/69c17bd504841ec9248cfad2/cover_61a3d984.jpg","original_filename":"cover_12. Why Meril selected ASTM F138-139 new.pdf.jpg","content_type":"image/jpeg","size":382995,"uploaded_at":"2026-03-26T05:54:19.722071+00:00","source":"family_propagation","width":1653,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"MERILISA HIV Gen 4 ELISA Kit | MERILISA ELISA - MedDevice Pro Telangana","seo_meta_description":"MERILISA HIV Gen 4 is an advanced fourth-generation ELISA diagnostic kit designed for accurate HIV screening in clinical laboratories. This enzyme-linked imm...","pack_size":"Not specified","size_variables":[],"created_at":"2026-03-25T13:11:00.715074+00:00","updated_at":"2026-03-26T14:44:33.870643+00:00","division_canonical":"Diagnostics","division_live_original":"Diagnostics","category":"ELISA","material_canonical":"Titanium (Pure/CP)","material_live_original":"Titanium","manufacturer":"Meril Life Sciences","description_live":"MERILISA HIV Gen 4 is an advanced fourth-generation ELISA diagnostic kit designed for accurate HIV screening in clinical laboratories. This enzyme-linked immunosorbent assay detects both HIV antigen and antibodies with enhanced sensitivity and specificity. Compatible with automated laboratory systems, it streamlines workflow for high-volume testing while ensuring reliable results for patient diagnosis and blood bank screening.","technical_specifications":{"generation":"Gen 4","platform":"ELISA","automation":"Compatible with automated systems"},"brand":"MERILISA","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.5,"catalog_created_at":"2026-03-27T16:50:59.617539+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Fourth-Generation HIV p24 Antigen and Antibody Detection Assay","proposed_clinical_display_title":"MERILISA HIV Gen 4 ELISA Kit","proposed_clinical_subtitle":"Fourth-Generation HIV p24 Antigen and Antibody Detection Assay","proposed_conflict_detected":true,"proposed_enriched_at":"2026-03-28T05:03:44.280408+00:00","proposed_entity_type":"diagnostic_kit","proposed_reasoning_summary":"Internal classification incorrectly lists material=Titanium (Pure/CP), which is clearly erroneous for a diagnostic ELISA kit. This is an in vitro diagnostic product, not an implantable device. Both internal brochure and external tier1_manufacturer sources confirm this is MERILISA HIV Gen 4, a fourth-generation enzyme-linked immunosorbent assay for detecting both HIV p24 antigen and HIV antibodies. The 'Gen 4' designation refers to the generation of HIV testing technology (simultaneous antigen/antibody detection), not a device generation. Brand is MERILISA (Meril's diagnostic brand). Current title 'HIV Gen 4' is too generic and lacks brand attribution. Recommended action: rename to include MERILISA brand and clarify this is an ELISA kit. The Titanium material classification should be removed as a data entry error. No evidence of conflict between sources—all align on product identity. Division=Diagnostics and category=ELISA are correct.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":[],"proposed_semantic_brand_system":"MERILISA","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"MERILISA HIV Testing","proposed_semantic_implant_class":null,"proposed_semantic_material_default":null,"proposed_semantic_parent_brand":"MERILISA","proposed_semantic_procedure_scope":["HIV Screening","HIV Diagnosis","Blood Donor Testing","Serology Testing"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"ELISA Immunoassay Platform","proposed_semantic_use_case_tags":["Fourth-generation HIV test","p24 antigen detection","HIV antibody detection","Early HIV detection","Clinical laboratory screening","Automated system compatible","High-volume testing"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":[],"semantic_brand_system":"MERILISA","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:46:54.706379+00:00","semantic_implant_class":null,"semantic_material_default":null,"semantic_parent_brand":"MERILISA","semantic_review_required":false,"semantic_rule_hits":["BULK_APPROVE_EXTERNALLY_VERIFIED"],"semantic_system_type":"ELISA Immunoassay Platform"}}]
