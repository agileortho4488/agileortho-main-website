00:00","division_canonical":"Cardiovascular","division_live_original":"Cardiovascular","category":"Heart Valves","material_canonical":"Bovine pericardium, Elgiloy alloy wireform, PET film structure, Polyester knit fabric, Acetal Polymer support ring","material_live_original":"Bovine pericardium, Elgiloy alloy wireform, PET film structure, Polyester knit fabric, Acetal Polymer support ring","manufacturer":"Meril Life Sciences","description_live":"Tri-leaflet stented bioprosthesis designed for mitral valve replacement with black sutures to reduce commissure profile for easier implantation. Features bovine pericardium tissue with proprietary anti-calcification treatment and commissural markers for optimal suture placement.","technical_specifications":{"Storage Temperature":"10°C to 25°C (50-77°F)","Storage Solution":"0.625% Glutaraldehyde","Rinse Procedure":"1 min rinse each in first 3 bowls of normal saline; leave in 4th bowl with normal saline until implantation","MRI Safety Information":"MR conditional at 1.5 and 3.0 Tesla","Aortic Valve Size 17mm (DDLN 17A)":"Tissue Annulus: 17mm, Int. Stent Post: 16mm, Ext. Sewing Ring: 23mm, Total Profile Height: 14mm","Aortic Valve Size 19mm (DDLN 19A)":"Tissue Annulus: 19mm, Int. Stent Post: 18mm, Ext. Sewing Ring: 25mm, Total Profile Height: 14mm","Aortic Valve Size 21mm (DDLN 21A)":"Tissue Annulus: 21mm, Int. Stent Post: 20mm, Ext. Sewing Ring: 27mm, Total Profile Height: 15mm","Aortic Valve Size 23mm (DDLN 23A)":"Tissue Annulus: 23mm, Int. Stent Post: 22mm, Ext. Sewing Ring: 29mm, Total Profile Height: 16mm","Aortic Valve Size 25mm (DDLN 25A)":"Tissue Annulus: 25mm, Int. Stent Post: 24mm, Ext. Sewing Ring: 31mm, Total Profile Height: 17mm","Aortic Valve Size 27mm (DDLN 27A)":"Tissue Annulus: 27mm, Int. Stent Post: 26mm, Ext. Sewing Ring: 33mm, Total Profile Height: 18mm","Aortic Valve Size 29mm (DDLN 29A)":"Tissue Annulus: 29mm, Int. Stent Post: 28mm, Ext. Sewing Ring: 35mm, Total Profile Height: 18mm","Mitral Valve Size 23mm (DDLN 23M)":"Stent Dia: 23mm, Int. Stent Post: 26.5mm, Ext. Stent Post: 27mm, Ext. Sewing Ring: 33mm, Ventricular Protrusion: 9mm, Total Profile Height: 15mm","Mitral Valve Size 25mm (DDLN 25M)":"Stent Dia: 25mm, Int. Stent Post: 28.5mm, Ext. Stent Post: 29mm, Ext. Sewing Ring: 36mm, Ventricular Protrusion: 10mm, Total Profile Height: 16mm","Mitral Valve Size 27mm (DDLN 27M)":"Stent Dia: 27mm, Int. Stent Post: 30.5mm, Ext. Stent Post: 31mm, Ext. Sewing Ring: 38mm, Ventricular Protrusion: 11mm, Total Profile Height: 17mm","Mitral Valve Size 29mm (DDLN 29M)":"Stent Dia: 29mm, Int. Stent Post: 33mm, Ext. Stent Post: 33.5mm, Ext. Sewing Ring: 41mm, Ventricular Protrusion: 12mm, Total Profile Height: 18mm","Mitral Valve Size 31mm (DDLN 31M)":"Stent Dia: 31mm, Int. Stent Post: 35mm, Ext. Stent Post: 35.5mm, Ext. Sewing Ring: 43mm, Ventricular Protrusion: 12mm, Total Profile Height: 18mm","Mitral Valve Size 33mm (DDLN 33M)":"Stent Dia: 33mm, Int. Stent Post: 37mm, Ext. Stent Post: 37.5mm, Ext. Sewing Ring: 45mm, Ventricular Protrusion: 12mm, Total Profile Height: 19mm"},"brand":"Dafodil","parent_brand":"","description_shadow":"The Dafodil Neo is a tri-leaflet stented bioprosthesis featuring a triple-composite design with bovine pericardium tissue and a triad-frame design utilizing an elgiloy alloy wireform. It incorporates the proprietary Anti Ca+ anti-calcification treatment to ensure long-term durability and hemodynamics support.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.5,"catalog_created_at":"2026-03-27T16:50:59.805153+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"Dafodil Mitral Bioprosthetic Heart Valve","proposed_clinical_subtitle":"Stented Bovine Pericardial Valve with Anti-Calcification Treatment","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:54:50.438682+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Internal evidence is comprehensive and clinically coherent. This is a specific implant class within the Dafodil Heart Valves product family, distinguished by anatomical position (mitral) and material (bovine pericardial bioprosthesis). Brochure description provides detailed technical specifications including tri-leaflet design, stented construction, Elgiloy alloy wireform, black sutures for reduced commissure profile, and proprietary anti-calcification treatment. Material composition is fully documented (bovine pericardium, Elgiloy alloy, PET film, polyester knit, acetal polymer). MR conditional safety and storage specifications are provided. The entity represents a specific valve type within a broader product family, not the family itself. No external verification needed as internal documentation is complete and unambiguous. Brand is clearly 'Dafodil' from product_family and brochure_heading. No conflicts detected.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Mitral valve","Left atrioventricular orifice"],"proposed_semantic_brand_system":"Dafodil","proposed_semantic_coating_default":"Proprietary anti-calcification treatment","proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Dafodil Heart Valves","proposed_semantic_implant_class":"Stented Mitral Bioprosthesis","proposed_semantic_material_default":"Bovine pericardium","proposed_semantic_parent_brand":"Dafodil Heart Valves","proposed_semantic_procedure_scope":["Mitral valve replacement","Open-heart surgery"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Bioprosthetic Heart Valve System","proposed_semantic_use_case_tags":["Mitral valve disease","Mitral regurgitation","Mitral stenosis","Valve replacement","Bioprosthetic implant"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Mitral valve","Left atrioventricular orifice"],"semantic_brand_system":"Dafodil","semantic_coating_default":"Proprietary anti-calcification treatment","semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.513608+00:00","semantic_implant_class":"Stented Mitral Bioprosthesis","semantic_material_default":"Bovine pericardium","semantic_parent_brand":"Dafodil Heart Valves","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Bioprosthetic Heart Valve System","clinical_indications":["Aortic valve replacement","Mitral valve replacement"],"materials_canonical":"Bovine pericardium tissue","features_list":["Anti Ca+ proprietary Anti Calcification Treatment","Triple-Composite design for optimal Effective Orifice Area (EOA)","Triad-frame design providing robustness via superior spring efficiency","Reduced sewing ring diameter and mitral protrusion for enhanced implantability","Black sutures in Mitral valves to reduce commissure profile","Commissural markers for facilitated suture placement","Elgiloy alloy wireform for radio-opacity and handling characteristics"],"brochure_intelligence_updated":true}}]
