le updated to include KET brand for accuracy.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Upper Extremity","Lower Extremity","Small Bone Fractures"],"proposed_semantic_brand_system":"KET Locking Plate System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"KET 3.5mm Locking Plate System","proposed_semantic_implant_class":"Small Fragment Locking Compression Plate","proposed_semantic_material_default":"Stainless Steel 316 LVM","proposed_semantic_parent_brand":"KET Trauma Fixation","proposed_semantic_procedure_scope":["Fracture Fixation","Trauma Reconstruction","Osteosynthesis"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Locking Compression Plate System","proposed_semantic_use_case_tags":["small fragment fixation","angular stable locking","compression plating","trauma surgery","low profile design"],"proposed_web_verification_status":"review_required_conflict"}}]
