hadow_product_id":"78a79c60138b5ef8","shadow_source_files":["AGFN Brochure.pdf"],"shadow_source_pages":[10],"shadow_sku_count":756,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"shadow","parent_brand":"shadow","description_shadow":"shadow","shadow_source_files":"shadow"},"enriched_from_shadow":true,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.6,"catalog_created_at":"2026-03-27T16:50:59.658170+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Meril (AGFN System) by Meril","proposed_clinical_display_title":"AGFN Locking Bolts - 4.9mm Self-Tapping","proposed_clinical_subtitle":"Self-tapping locking screws for AGFN femoral nail fixation","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:22:28.409340+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"This is a component/instrument product family within the AGFN (Antirotation Gamma Femoral Nail) system. The brochure clearly identifies these as 4.9mm diameter self-tapping locking bolts specifically designed for AGFN femoral nail fixation. While terminology uses 'bolts', these are clinically locking screws used to secure the intramedullary nail. The product family is correctly classified as locking screws within the Trauma division. Material specification (Ti-6Al-7Nb) is clearly stated. SKU examples show consistent naming with TAN (Titanium Alloy) designation and varying lengths (26-34mm implied from SKU numbers). The AGFN system is a proximal femoral nail system, so anatomy scope is femur/proximal femur. No conflicts detected. Internal evidence is sufficient and consistent. Current title accurately reflects the product; no renaming needed.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Femur","Proximal Femur"],"proposed_semantic_brand_system":"AGFN System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"AGFN Locking Screws","proposed_semantic_implant_class":"Locking Screw","proposed_semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","proposed_semantic_parent_brand":"Meril","proposed_semantic_procedure_scope":["Intramedullary Nailing","Femoral Fracture Fixation","Proximal Femoral Fracture Fixation"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Intramedullary Nail System","proposed_semantic_use_case_tags":["Fracture Fixation","Trauma","Locking Fixation","Self-Tapping"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Femur","Proximal Femur"],"semantic_brand_system":"AGFN System","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.494008+00:00","semantic_implant_class":"Locking Screw","semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","semantic_parent_brand":"Meril","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Intramedullary Nail System"}}]
