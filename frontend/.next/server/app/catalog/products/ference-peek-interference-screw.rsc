mantic_brand_system":"FERENCE-PEEK","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"FERENCE Interference Screw Family","proposed_semantic_implant_class":"Interference Screw","proposed_semantic_material_default":"Polyether Ether Ketone (PEEK)","proposed_semantic_parent_brand":"FERENCE","proposed_semantic_procedure_scope":["ACL Reconstruction","PCL Reconstruction","Bone-Tendon-Bone Graft Fixation","Tenodesis","Soft Tissue Graft Fixation"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Interference Screw System","proposed_semantic_use_case_tags":["Graft Fixation","Ligament Reconstruction","Radiolucent","MRI Compatible","Revisable","Blunt Tip Design","Soft Tissue Compatible","BTB Compatible"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Knee"],"semantic_brand_system":"FERENCE-PEEK","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.038899+00:00","semantic_implant_class":"Interference Screw","semantic_material_default":"Polyether Ether Ketone (PEEK)","semantic_parent_brand":"FERENCE","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Interference Screw System"}}]
