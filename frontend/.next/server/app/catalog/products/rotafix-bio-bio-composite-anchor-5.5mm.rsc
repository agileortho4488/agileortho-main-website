clinical_subtitle":"","proposed_clinical_display_title":"ROTAFIX-BIO Bio-Composite Suture Anchor","proposed_clinical_subtitle":"5.5mm PLGA + β-TCP Resorbable Anchor for Shoulder Soft Tissue Repair","proposed_conflict_detected":true,"proposed_enriched_at":"2026-03-28T06:33:34.768099+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Clear internal evidence describes a 5.5mm bio-composite resorbable suture anchor with PLGA + β-TCP material for shoulder arthroscopy. However, critical ambiguity exists: product is named 'ROTAFIX-BIO' and classified under 'ROTAFIX Titanium Anchors' family—these are contradictory material claims. Bio-composite PLGA anchors are fundamentally different from titanium anchors in mechanism (resorbable vs. permanent), indications, and product positioning. The brochure heading 'ROTAFIX Titanium Anchors' appears to be incorrect family assignment. Product likely belongs to a separate 'ROTAFIX-BIO' or 'ROTAFIX Bio-Composite' family. Brand field is empty, which prevents proper hierarchy determination. Without external verification or additional catalog structure, cannot definitively resolve whether this is a distinct product line or mis-categorized variant. Clinical meaning is clear (bio-composite resorbable anchor), but taxonomy placement requires human review to prevent incorrect family grouping with titanium anchors.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Shoulder","Rotator Cuff","Labrum"],"proposed_semantic_brand_system":"ROTAFIX","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"ROTAFIX Suture Anchor Platform","proposed_semantic_implant_class":"Bio-Composite Resorbable Suture Anchor","proposed_semantic_material_default":"PLGA + β-TCP Bio-Composite","proposed_semantic_parent_brand":"ROTAFIX Titanium Anchors","proposed_semantic_procedure_scope":["Arthroscopic Soft Tissue Repair","Rotator Cuff Repair","Labral Repair","Capsular Repair"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Suture Anchor System","proposed_semantic_use_case_tags":["resorbable anchor","bio-composite","dual thread design","cortical and cancellous bone fixation","gradual resorption","bone remodeling"],"proposed_web_verification_status":"review_required_ambiguity"}}]]}]]}],false,"$undefined","$L16","$L17"]}]]}]
