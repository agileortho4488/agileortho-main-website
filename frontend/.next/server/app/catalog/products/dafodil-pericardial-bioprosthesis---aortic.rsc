mm","external_sewing_ring_diameter":"36mm"}],"created_at":"2026-03-26T02:39:26.891934+00:00","updated_at":"2026-03-26T14:44:33.952159+00:00","division_canonical":"Cardiovascular","division_live_original":"Cardiovascular","category":"Heart Valves","material_canonical":"Bovine pericardium, Elgiloy alloy wireform, PET film structure, Polyester knit fabric, Acetal Polymer support ring","material_live_original":"Bovine pericardium, Elgiloy alloy wireform, PET film structure, Polyester knit fabric, Acetal Polymer support ring","manufacturer":"Meril Life Sciences","description_live":"Tri-leaflet stented bioprosthesis designed for aortic valve replacement with triple-composite design providing optimal Effective Orifice Area (EOA). Features bovine pericardium tissue with proprietary anti-calcification treatment and Elgiloy alloy wireform for superior radio-opacity and handling characteristics.","technical_specifications":{"Storage Temperature":"10 °C to 25 °C (50-77 °F)","Storage Solution":"Glutaraldehyde","Rinse Procedure":"1 min rinse each in first 3 bowls; store in 4th bowl prior to implantation","MRI Safety Information":"MR conditional at 1.5 and 3.0 Tesla","Aortic Available Sizes":"19mm, 21mm, 23mm, 25mm, 27mm","Mitral Available Sizes":"23mm, 25mm, 27mm, 29mm, 31mm","Aortic Tissue Annulus Diameter Range":"20mm to 28.5mm","Aortic External Sewing Ring Diameter Range":"27mm to 36mm","Mitral External Sewing Ring Diameter Range":"33mm to 43mm","Mitral Stent Diameter (Wire Form) Range":"23mm to 29mm"},"brand":"Dafodil","parent_brand":"","description_shadow":"Dafodil is a tri-leaflet stented bioprosthesis composed of bovine pericardium tissue treated with a proprietary anti-calcification process. It features a Triad-frame design with an Elgiloy alloy wireform and a Triple-Composite design for optimal hemodynamics and durability.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"fuzzy_token","match_score":0.5,"catalog_created_at":"2026-03-27T16:50:59.804235+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"","proposed_clinical_display_title":"Dafodil Pericardial Bioprosthesis","proposed_clinical_subtitle":"Aortic Valve Replacement","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:54:37.924377+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Internal evidence is comprehensive and clinically coherent. Product is clearly a stented bioprosthetic heart valve specifically designed for aortic valve replacement. The brochure description provides detailed technical specifications: tri-leaflet design, bovine pericardium tissue, Elgiloy alloy wireform, proprietary anti-calcification treatment, and triple-composite construction. Classification data confirms MR conditional status, glutaraldehyde storage, and specific handling characteristics. Manufacturer identified as Meril Life Sciences. The 'Dafodil' brand name is evident from product_family and brochure_heading. Current title accurately reflects the product - it is a specific implant class (aortic position) within the Dafodil product family. No external verification needed as internal evidence is definitive for a medical device catalog. No conflicts detected. Brand is 'Dafodil', not missing - can be extracted from product_family field.","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Aortic Valve","Aortic Position"],"proposed_semantic_brand_system":"Dafodil","proposed_semantic_coating_default":"Proprietary Anti-Calcification Treatment","proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"Dafodil Heart Valves","proposed_semantic_implant_class":"Aortic Heart Valve Bioprosthesis","proposed_semantic_material_default":"Bovine Pericardium","proposed_semantic_parent_brand":"Dafodil Heart Valves","proposed_semantic_procedure_scope":["Aortic Valve Replacement","AVR"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Stented Bioprosthetic Heart Valve","proposed_semantic_use_case_tags":["Stented Bioprosthesis","Tri-leaflet Design","Triple-Composite Construction","MR Conditional","Anti-Calcification","Elgiloy Wireform","Optimal EOA"],"proposed_web_verification_status":"internally_verified","semantic_anatomy_scope":["Aortic Valve","Aortic Position"],"semantic_brand_system":"Dafodil","semantic_coating_default":"Proprietary Anti-Calcification Treatment","semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.513166+00:00","semantic_implant_class":"Aortic Heart Valve Bioprosthesis","semantic_material_default":"Bovine Pericardium","semantic_parent_brand":"Dafodil Heart Valves","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_INTERNALLY_VERIFIED"],"semantic_system_type":"Stented Bioprosthetic Heart Valve","clinical_indications":["Aortic valve replacement","Mitral valve replacement"],"materials_canonical":"Bovine pericardium tissue","features_list":["AntiCa proprietary anti-calcification process for long-term durability","Triple-Composite design for optimal Effective Orifice Area (EOA)","Laser-cut independent pericardial leaflets for absolute uniformity","Triad-frame design with Elgiloy alloy wireform for robustness","Black sutures in Mitral valves to ease implantation in the Mitral annulus","Commissural markers on sewing ring for suture placement and orientation","Radio-opaque wireform for visibility under imaging"],"brochure_intelligence_updated":true}}]
