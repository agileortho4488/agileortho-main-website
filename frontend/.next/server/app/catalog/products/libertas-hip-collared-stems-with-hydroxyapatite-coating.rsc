"division_live_original":"Joint Replacement","category":"Hip Stems","material_canonical":"Hydroxyapatite coated metal","material_live_original":"Hydroxyapatite coated metal","manufacturer":"Maxx Orthopedics, Inc.","description_live":"Hydroxyapatite coated hip stems with collared design engineered for stability and long-term fixation. Features stepped geometry to minimize shear forces and maximize compression loading while preventing subsidence through collar protection.","technical_specifications":{"coating":"Hydroxyapatite (HA) coating on bone-mating surface","geometry":"Stepped geometry with collar","ccd_angles":"125° and 135°","horizontal_offset_range":"38.5mm - 53.0mm","stem_length_range":"130.0mm - 195.0mm","neck_length":"38.8mm (standard)","fixation_type":"Cemented use only","subsidence_protection":"Collar design"},"brand":"LIBERTAS","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.761306+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Cemented femoral stems with HA coating and collar design for subsidence protection","proposed_clinical_display_title":"LIBERTAS Collared Hip Stems with Hydroxyapatite Coating","proposed_clinical_subtitle":"Cemented femoral stems with HA coating and collar design for subsidence protection","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:46:00.711324+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"This is a well-defined product family of cemented femoral hip stems with specific design features (collar, HA coating, stepped geometry). Internal evidence is detailed and internally consistent. However, there is an unusual specification requiring review: cemented stems typically do NOT have hydroxyapatite coating, as HA is a bone-ingrowth promoting coating used for cementless/press-fit implants. The combination of 'cemented use only' with 'hydroxyapatite coating on bone-mating surface' is clinically atypical and may represent: (1) a hybrid design concept, (2) an error in specification, or (3) HA coating intended for cement-bone interface enhancement rather than bone ingrowth. Brand is missing (manufacturer listed as Maxx Orthopedics). This requires clinical review to verify the intended fixation method and coating purpose before publication.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Hip","Femur","Proximal Femur"],"proposed_semantic_brand_system":"LIBERTAS","proposed_semantic_coating_default":"Hydroxyapatite (HA)","proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"LIBERTAS Cemented Collared Stems","proposed_semantic_implant_class":"Femoral Stem - Cemented - Collared","proposed_semantic_material_default":"Metal alloy","proposed_semantic_parent_brand":"LIBERTAS Hip System","proposed_semantic_procedure_scope":["Total Hip Arthroplasty","Hip Replacement"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Total Hip Arthroplasty System","proposed_semantic_use_case_tags":["cemented fixation","collared design","subsidence prevention","hydroxyapatite coating","stepped geometry","compression loading"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Hip","Femur","Proximal Femur"],"semantic_brand_system":"LIBERTAS","semantic_coating_default":"Hydroxyapatite (HA)","semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.145922+00:00","semantic_implant_class":"Femoral Stem - Cemented - Collared","semantic_material_default":"Metal alloy","semantic_parent_brand":"LIBERTAS Hip System","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Total Hip Arthroplasty System"}}]
