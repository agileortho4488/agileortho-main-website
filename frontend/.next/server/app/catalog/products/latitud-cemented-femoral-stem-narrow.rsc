3) obtain product literature or SKU structure.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Proximal Femur","Hip Joint"],"proposed_semantic_brand_system":"LATITUD","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"LATITUD Cemented Femoral Stem - Narrow Variant","proposed_semantic_implant_class":"Cemented Femoral Stem","proposed_semantic_material_default":"Stainless Steel (Surgical Grade)","proposed_semantic_parent_brand":"LATITUD Hip System","proposed_semantic_procedure_scope":["Total Hip Arthroplasty","Hip Replacement"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Cemented Hip Arthroplasty System","proposed_semantic_use_case_tags":["Narrow Femoral Canal","Small Canal Dimensions","Cemented Fixation","Asian Morphology","Petite Patients"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Proximal Femur","Hip Joint"],"semantic_brand_system":"LATITUD","semantic_coating_default":null,"semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.164049+00:00","semantic_implant_class":"Cemented Femoral Stem","semantic_material_default":"Stainless Steel (Surgical Grade)","semantic_parent_brand":"LATITUD Hip System","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Cemented Hip Arthroplasty System"}}]
