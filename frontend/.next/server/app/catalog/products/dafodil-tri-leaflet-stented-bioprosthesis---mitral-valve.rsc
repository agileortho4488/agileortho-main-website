ily. All sources align on core attributes: bovine pericardial tissue, stented design, triad frame, MR conditional safety. The current title accurately reflects the clinical entity. No conflicts detected between internal catalog data and manufacturer sources. Classification is verified and can be enriched with confirmed manufacturer (Meril Life Sciences).","proposed_recommended_action":"keep_as_is","proposed_semantic_anatomy_scope":["Mitral valve"],"proposed_semantic_brand_system":"Dafodil","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.92,"proposed_semantic_family_group":"Dafodil Heart Valves","proposed_semantic_implant_class":"Stented Bioprosthetic Heart Valve","proposed_semantic_material_default":"Bovine pericardium","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Mitral valve replacement","Cardiac valve surgery"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Bioprosthetic Heart Valve System","proposed_semantic_use_case_tags":["Diseased mitral valve replacement","MRI conditional imaging","Long-term cardiac care","Hemodynamic optimization"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Mitral valve"],"semantic_brand_system":"Dafodil","semantic_coating_default":null,"semantic_confidence":0.92,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.450078+00:00","semantic_implant_class":"Stented Bioprosthetic Heart Valve","semantic_material_default":"Bovine pericardium","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Bioprosthetic Heart Valve System"}}]
