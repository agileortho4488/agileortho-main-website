1a:T478,Internal evidence clearly identifies this as the MIRUS Auto Linear Stapler product family within Endo Surgery division. The brochure description provides detailed technical features: reloadable design, parallel jaw closure, single-hand ergonomic operation, and adjustable intermediate locking positions for tissue management. Material is specified as Titanium with 2-row stapling configuration. However, no external verification sources were found, brand field is empty in metadata (though MIRUS appears in product_family and brochure_heading), and no SKU examples exist. The device type (linear stapler) is a well-understood surgical instrument used in laparoscopic and open procedures for tissue resection and anastomosis. Given missing external validation and the absence of brand confirmation in metadata despite clear internal naming convention, review is required to: 1) Confirm MIRUS as the official brand system, 2) Verify this represents the complete product family vs. a subset, 3) Validate technical specifications against manufacturer documentation, 4) Confirm anatomy scope assumptions based on typical linear stapler applications.15:["$","$L19",null,{"product":{"product_name":"MIRUS Auto Linear Stapler","product_name_display":"Auto Linear Stapler","sku_code":"MALS-AUT-001","product_family":"MIRUS Auto Linear Stapler","product_family_display":"MIRUS Auto Linear Stapler","slug":"mirus-auto-linear-stapler","images":[{"id":"prop_69c4214","storage_path":"agile-ortho/products/69c17bd504841ec9248cfada/cover_b7bd3361.jpg","original_filename":"cover_Endo P1 Product Range.pdf.jpg","content_type":"image/jpeg","size":718573,"uploaded_at":"2026-03-26T05:55:53.511695+00:00","source":"family_propagation","width":4410,"height":1750}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"Auto Linear Stapler | MIRUS Staplers - MedDevice Pro Telangana","seo_meta_description":"Reloadable linear stapler with parallel jaw closure and ergonomic single-hand design. Features adjustable intermediate locking position for precise tissue ma...","pack_size":"Single use","size_variables":["30mm","45mm","60mm","90mm"],"created_at":"2026-03-25T17:54:12.056420+00:00","updated_at":"2026-03-26T14:44:33.916045+00:00","division_canonical":"Endo Surgery","division_live_original":"Endo-surgical","category":"Staplers","material_canonical":"Titanium (Pure/CP)","material_live_original":"Titanium staples","manufacturer":"Meril Life Sciences","description_live":"Reloadable linear stapler with parallel jaw closure and ergonomic single-hand design. Features adjustable intermediate locking position for precise tissue management.","technical_specifications":{"MIRUS Powered Endocutter Units":"MEC60-280 (60mm Small), MEC60-340 (60mm Medium), MEC60-440 (60mm Long), MEC45-280 (45mm Small), MEC45-340 (45mm Medium), MEC45-440 (45mm Long)","Powered Endocutter Reloads (Staple Leg Length)":"MECRW (2.5mm White), MECRB (3.5mm Blue), MECRGD (3.8mm Gold), MECRG (4.1mm Green), MECRT (4.4mm Black)","Trio Reloads (Stapler Size Inner to Outer)":"Vascular Medium (White): 2.0-3.0mm; Medium Thick (Purple): 3.0-4.0mm; Extra Thick (Black): 4.0-5.0mm","MIRUS Linear Cutter (MLC Series)":"MLC60 (64mm Staples line, 60mm Cut), MLC80 (84mm Staples line, 80mm Cut), MLC100 (104mm Staples line, 100mm Cut); Rows: 4, Staples: 64/84/104","MIRUS Auto Linear Stapler (MALS Series)":"MALS30 (11 staples, 2 rows), MALS45 (15 staples, 2 rows), MALS60 (21 staples, 2 rows), MALS90 (33 staples, 2 rows); Lengths: 3.5mm (Blue) / 4.8mm (Green)","MIRUS Circular Stapler - III Rows (Variants)":"MCS-21R3 (Cut 12mm, Head 21mm, 21 staples), MCS-24R3 (Cut 15mm, Head 24mm, 24 staples), MCS-25R3 (Cut 16mm, Head 25mm, 27 staples), MCS-26R3 (Cut 17mm, Head 26mm, 33 staples), MCS-29R3 (Cut 20mm, Head 29mm, 36 staples), MCS-31R3 (Cut 21mm, Head 31mm, 36 staples), MCS-32R3 (Cut 22mm, Head 32mm, 42 staples)","MIRUS Hemorrhoids Stapler (PPH)":"MPPH32 (32mm, 2 rows, 32 staples), MPPH34 (34mm, 2 rows, 32 staples), MPPH34R3 (34mm, 3 rows, 48 staples), MPPH36R3 (36mm, 3 rows, 48 staples); Closed staple height: 0.75-1.6mm","MERINEUM Mesh Technical Matrix":"Pore Size: 1.8-2 mm; Pre-Absorption Weight: 185 gsm; Post-Absorption Weight: 40 gsm; Thickness: 0.5-0.6 mm; Initial Burst Strength: 350 N","MERIGROW Mesh Technical Matrix":"Material: Polypropylene; Pore size: 1.5-2.3 mm; Weight: 55 gsm; Burst strength: 98.06 N/cm2; Thickness: 0.60 mm","MESIC Laser Ablation Technical Data":"Laser Type: GaAiAs Diode; Wavelength: 1470nm; Max Power: 12W; Pulse Duration: 10us - 3s; Repetition: 1 Hz-20KHz; Weight: 2.1 Kg","PROFOUND Mesh Fixation Spikes":"MFD15A/MFD15N (15 spikes), MFD30A/MFD30N (30 spikes); Tube diameter: 5 mm; Length: 36 cm"},"brand":"MIRUS","parent_brand":"","description_shadow":"A comprehensive suite of advanced surgical tools including powered and manual endoscopic staplers, titanium mechanical stapling devices, composite and macroporous hernia meshes, energy-based resection systems, and handheld robotic articulation devices for minimally invasive surgery.","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"fuzzy_token","match_score":0.4,"catalog_created_at":"2026-03-27T16:50:59.716829+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Reloadable Linear Stapler with Parallel Jaw Closure","proposed_clinical_display_title":"MIRUS Auto Linear Stapler","proposed_clinical_subtitle":"Reloadable Linear Stapler with Parallel Jaw Closure","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:36:36.926988+00:00","proposed_entity_type":"product_family","proposed_reasoning_summary":"$1a","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Gastrointestinal","Thoracic","General Surgical Tissue"],"proposed_semantic_brand_system":"MIRUS","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.75,"proposed_semantic_family_group":"Endo Surgery Staplers","proposed_semantic_implant_class":"Linear Surgical Stapler","proposed_semantic_material_default":"Titanium","proposed_semantic_parent_brand":"MIRUS","proposed_semantic_procedure_scope":["Laparoscopic Surgery","Open Surgery","Tissue Resection","Tissue Anastomosis"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Surgical Stapling System","proposed_semantic_use_case_tags":["Reloadable","Parallel Jaw Closure","Single-Hand Operation","Adjustable Locking","Two-Row Stapling"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Gastrointestinal","Thoracic","General Surgical Tissue"],"semantic_brand_system":"MIRUS","semantic_coating_default":null,"semantic_confidence":0.75,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.138752+00:00","semantic_implant_class":"Linear Surgical Stapler","semantic_material_default":"Titanium","semantic_parent_brand":"MIRUS","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE3_INHERIT_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Surgical Stapling System","clinical_indications":["Laparoscopic Ventral Hernia Repair","Incisional Hernia Repair","Parastomal Hernia Repair","Umbilical Hernia Repair","Peritoneal Defect Closure","Open & Laparoscopic Inguinal Hernia Repair","E-TEP procedure","TAPP | TEP | ROBOTIC TAPP","EVLT/Varicose Vein","Fistula and Hemorrhoid procedures","Pilonidal sinus and Fissure treatment","General, Colorectal, and Oncology surgery","Gastroenterology and Thoracic surgery"],"materials_canonical":"Titanium (Staples, Spikes, and Fixation Alloy)","features_list":["Extra flexibility: Up to 60 degrees of maximum reach on Powered Endocutters","Optimal Tissue Management System with Trio stepped reloads","Dual side firing with safety lock for Linear Cutters","Staple compression gauge to ensure accurate formation across variable tissue thickness","Tissue Compression Indicator on Hemorrhoids stapler for proper B-shaped staple formation","Synthetic Absorbable Anti-adhesive PLCL barrier resorbs between 90-120 days","Advanced RTTI II Algorithm for rapid transaction in Ultrasonic shears","Fully articulated 7 Degrees of Freedom (DOF) on HandX robotic system","Optical entry trocars for tissue layer visualization during insertion"],"brochure_intelligence_updated":true}}]
