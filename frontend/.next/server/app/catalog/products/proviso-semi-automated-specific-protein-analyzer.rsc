7:["$","div",null,{"className":"min-h-screen bg-[#0A0A0A] text-white","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org/\",\"@type\":\"Product\",\"name\":\"Proviso Semi-Automated Specific Protein Analyzer\",\"description\":\"The Proviso Semi-Automated Specific Protein Analyzer delivers precise photometric and nephelometric analysis for critical protein diagnostics in hospital laboratories. This advanced diagnostic system features 620nm laser LED technology with dual photodiode detectors, processing whole blood, serum, urine, and citrate plasma samples with automated mixing and 37°C incubation. With 5000 result storage capacity and intuitive TFT LCD touchscreen interface, it streamlines protein analysis workflow for enhanced laboratory efficiency and accurate patient diagnostics.\",\"brand\":{\"@type\":\"Brand\",\"name\":\"Meril\"},\"category\":\"Biochemistry Analyzers\",\"manufacturer\":{\"@type\":\"Organization\",\"name\":\"Meril Life Sciences\"},\"offers\":{\"@type\":\"AggregateOffer\",\"offerCount\":\"1\",\"lowPrice\":\"0\",\"priceCurrency\":\"INR\",\"availability\":\"https://schema.org/InStock\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://agileortho.in\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Catalog\",\"item\":\"https://agileortho.in/catalog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Diagnostics\",\"item\":\"https://agileortho.in/catalog/diagnostics\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Proviso Semi-Automated Specific Protein Analyzer\",\"item\":\"https://agileortho.in/catalog/products/proviso-semi-automated-specific-protein-analyzer\"}]}"}}],["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24","children"