","protein quantification","photometry","nephelometry","automated incubation","multi-sample processing"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":[],"semantic_brand_system":"Proviso","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.476723+00:00","semantic_implant_class":"N/A - Diagnostic Instrument","semantic_material_default":null,"semantic_parent_brand":"Meril Diagnostics","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Semi-Automated Clinical Chemistry Analyzer"}}]
