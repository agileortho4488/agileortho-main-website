16:["$","$L19",null,{"product":{"product_name":"Meriscreen HIV 1-2 Ab Quadro","product_name_display":"QUADRO HIV 1-2 Ab Rapid Test","sku_code":"MRL-DIA-001","product_family":"Meriscreen HIV 1-2 Ab Quadro","product_family_display":"Meriscreen HIV 1-2 Ab Quadro","slug":"meriscreen-hiv-1-2-ab-quadro","images":[{"id":"225ba25e18c9","storage_path":"agile-ortho/products/69c2c2193532547dbd61c5e2/cover_a6dc74f9.jpg","original_filename":"cover_Quadro_Flyer.pdf.jpg","content_type":"image/jpeg","size":537503,"uploaded_at":"2026-03-26T05:58:20.069568+00:00","source":"brochure_extraction","width":1654,"height":2339},{"id":"27229e3beabb","storage_path":"agile-ortho/products/69c2c2193532547dbd61c5e2/cover_f9172393.jpg","original_filename":"cover_Quadro_Flyer.pdf.jpg","content_type":"image/jpeg","size":537503,"uploaded_at":"2026-03-26T06:02:33.885243+00:00","source":"brochure_extraction","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"QUADRO HIV 1-2 Ab Rapid Test | QUADRO Rapid Diagnostic Tests - MedDevice Pro Telangana","seo_meta_description":"Meriscreen HIV 1-2 Ab Quadro is a WHO-prequalified rapid diagnostic test utilizing advanced immunochromatographic membrane technology for accurate HIV antibo...","pack_size":"Not specified","size_variables":[],"created_at":"2026-03-24T16:55:53.928896+00:00","updated_at":"2026-03-26T14:44:33.826636+00:00","division_canonical":"Diagnostics","division_live_original":"Diagnostics","category":"Rapid Diagnostic Tests","material_canonical":"Immunochromatographic Membrane","material_live_original":"Immunochromatographic membrane","manufacturer":"Meril Life Sciences","description_live":"Meriscreen HIV 1-2 Ab Quadro is a WHO-prequalified rapid diagnostic test utilizing advanced immunochromatographic membrane technology for accurate HIV antibody detection. This 4-Dot Flowthrough format test provides reliable HIV-1 and HIV-2 screening results within minutes, ideal for point-of-care testing in hospitals and clinics. Room temperature storage capability ensures convenient inventory management while maintaining diagnostic accuracy and reliability for healthcare professionals.","technical_specifications":{"format":"4-Dot Flowthrough","storage":"Room temperature","certification":"WHO-prequalified"},"brand":"QUADRO","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"family_brand_division","match_score":0.625,"catalog_created_at":"2026-03-27T16:50:59.493264+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Rapid Immunochromatographic Test for HIV-1 and HIV-2 Antibody Detection","proposed_clinical_display_title":"QUADRO HIV 1-2 Ab Rapid Test","proposed_clinical_subtitle":"Rapid Immunochromatographic Test for HIV-1 and HIV-2 Antibody Detection","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:41:40.858516+00:00","proposed_entity_type":"diagnostic_kit","proposed_reasoning_summary":"This is a diagnostic rapid test kit for HIV antibody detection. All sources consistently confirm QUADRO HIV 1-2 Ab is a rapid flow-through qualitative immunoassay detecting antibodies to HIV-1 and HIV-2 in human serum/plasma. The product appears to be part of Meril's Meriscreen diagnostic portfolio, with QUADRO being the specific product brand/system name. Internal brochure confirms WHO prequalification, 4-Dot Flowthrough format, and point-of-care use. The current title 'HIV 1-2 Ab Quadro' has word order reversed - clinical convention places the brand/system name (QUADRO) before the analyte description. Recommend renaming to 'QUADRO HIV 1-2 Ab Rapid Test' for clarity and consistency with manufacturer nomenclature. No conflicts detected between internal and external sources. High confidence verification achieved.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Blood/Serum/Plasma"],"proposed_semantic_brand_system":"QUADRO","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.95,"proposed_semantic_family_group":"HIV Diagnostic Tests","proposed_semantic_implant_class":null,"proposed_semantic_material_default":"Immunochromatographic membrane","proposed_semantic_parent_brand":"Meriscreen","proposed_semantic_procedure_scope":["HIV screening","Point-of-care testing","Serological testing"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Rapid Diagnostic Test","proposed_semantic_use_case_tags":["HIV-1 antibody detection","HIV-2 antibody detection","Point-of-care diagnostics","Hospital laboratory testing","Clinic screening","WHO-prequalified","Flow-through assay","4-Dot format"],"proposed_web_verification_status":"externally_verified","semantic_anatomy_scope":["Blood/Serum/Plasma"],"semantic_brand_system":"QUADRO","semantic_coating_default":null,"semantic_confidence":0.95,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.447377+00:00","semantic_implant_class":null,"semantic_material_default":"Immunochromatographic membrane","semantic_parent_brand":"Meriscreen","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_VERIFIED"],"semantic_system_type":"Rapid Diagnostic Test"}}]
