16:["$","$L19",null,{"product":{"product_name":"Freedom Total Knee System - CR Femoral Component","product_name_display":"Freedom Total Knee System - CR Femoral Component","sku_code":"MRL-FTK-003","product_family":"Freedom Total Knee System - CR Femoral Component","product_family_display":"Freedom Total Knee System - CR Femoral Component","slug":"freedom-total-knee-system---cr-femoral-component","images":[{"id":"3968c8c14ee9","storage_path":"agile-ortho/products/69c17bd504841ec9248cfabb/cover_6899289c.jpg","original_filename":"cover_Destiknee Brochure.pdf.jpg","content_type":"image/jpeg","size":208705,"uploaded_at":"2026-03-26T05:55:44.917719+00:00","source":"division_fallback","width":1600,"height":1600}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"Freedom Total Knee System - CR Femoral Component | Freedom Total Knee System Knee Femoral Components - MedDevice Pro Telangana","seo_meta_description":"Cruciate Retaining (CR) femoral component for Freedom Total Knee System. Designed to preserve the posterior cruciate ligament for patients with intact PCL. P...","pack_size":"Individual sterile packaging","size_variables":["Size A","Size B","Size C","Size D","Size E","Size F","Size G","Size H"],"created_at":"2026-03-26T02:48:21.775840+00:00","updated_at":"2026-03-26T14:44:33.956300+00:00","division_canonical":"Joint Replacement","division_live_original":"Joint Replacement","category":"Knee Femoral Components","material_canonical":"Cobalt Chromium Alloy","material_live_original":"Cobalt Chromium Alloy","manufacturer":"Meril Life Sciences","description_live":"Cruciate Retaining (CR) femoral component for Freedom Total Knee System. Designed to preserve the posterior cruciate ligament for patients with intact PCL. Provides natural knee kinematics and proprioception.","technical_specifications":{"design_type":"Cruciate Retaining","pcl_preservation":"Yes","anatomical_design":"Yes","surface_finish":"Polished"},"brand":"Freedom Total Knee System","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.812045+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Cruciate Retaining Femoral Component with PCL Preservation","proposed_clinical_display_title":"Freedom Total Knee System CR Femoral Component","proposed_clinical_subtitle":"Cruciate Retaining Femoral Component with PCL Preservation","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T05:57:51.396187+00:00","proposed_entity_type":"implant_class","proposed_reasoning_summary":"Internal evidence clearly describes a CR (Cruciate Retaining) femoral component within the Freedom Total Knee System. This is a specific implant class component, not a product family. The brochure description provides clinical clarity: PCL-preserving design for patients with intact posterior cruciate ligament. Material specification (CoCr alloy) and design attributes (polished, anatomical) are consistent with standard TKA femoral components. However, brand owner is missing (Meril Life Sciences listed as manufacturer but no brand confirmation). No external verification available. The entity should be classified as an implant_class component rather than product_family since it represents one specific configuration (CR) within the broader Freedom TKA system. Review required to: 1) confirm Meril Life Sciences brand ownership, 2) verify if this should be nested under a parent Freedom TKA family page, and 3) determine relationship to potential PS (Posterior Stabilized) variant components.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Knee","Distal Femur"],"proposed_semantic_brand_system":"Freedom Total Knee System","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Freedom Total Knee System - CR Configuration","proposed_semantic_implant_class":"Cruciate Retaining Femoral Component","proposed_semantic_material_default":"Cobalt Chromium Alloy","proposed_semantic_parent_brand":"Freedom","proposed_semantic_procedure_scope":["Total Knee Arthroplasty","Cruciate Retaining TKA"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Total Knee Arthroplasty System","proposed_semantic_use_case_tags":["PCL Preservation","Natural Kinematics","Intact PCL Patients","Cruciate Retaining Design","Primary TKA"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Knee","Distal Femur"],"semantic_brand_system":"Freedom Total Knee System","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:48.947432+00:00","semantic_implant_class":"Cruciate Retaining Femoral Component","semantic_material_default":"Cobalt Chromium Alloy","semantic_parent_brand":"Freedom","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Total Knee Arthroplasty System"}}]
