16:["$","$L19",null,{"product":{"product_name":"ARMAR 3.5mm Locking Plate System Instrument Set","product_name_display":"KET 3.5mm Locking Plate System Instrument Set","sku_code":"MRL-ARM-INS02","product_family":"ARMAR 3.5mm Locking Plate System Instrument Set","product_family_display":"ARMAR 3.5mm Locking Plate System Instrument Set","slug":"armar-3.5mm-locking-plate-system-instrument-set","images":[{"id":"prop_69c2d2d","storage_path":"agile-ortho/products/69c2d2d07171238d2edca5ad/cover_93e430f9.jpg","original_filename":"cover_LBL_Plate_Chart_Meril.pdf.jpg","content_type":"image/jpeg","size":572912,"uploaded_at":"2026-03-26T05:56:24.795886+00:00","source":"family_propagation","width":1654,"height":2339}],"status":"published","live_visible":true,"brochure_url":"","seo_meta_title":"KET 3.5mm Locking Plate System Instrument Set | KET Surgical Instruments - MedDevice Pro Telangana","seo_meta_description":"The ARMAR 3.5mm Locking Plate System Instrument Set is a comprehensive trauma surgery solution featuring precision-engineered stainless steel surgical instru...","pack_size":"Set with Case","size_variables":["Complete Set"],"created_at":"2026-03-24T18:07:12.128771+00:00","updated_at":"2026-03-26T14:44:33.834407+00:00","division_canonical":"Instruments","division_live_original":"Instruments","category":"Surgical Instruments","material_canonical":"Stainless Steel (Surgical Grade)","material_live_original":"Stainless Steel","manufacturer":"Meril Life Sciences","description_live":"The ARMAR 3.5mm Locking Plate System Instrument Set is a comprehensive trauma surgery solution featuring precision-engineered stainless steel surgical instruments. This complete set includes 2.5mm, 2.8mm, and 3.5mm drill bits, torque limiter, depth gauge, and universal drill guides for optimal surgical outcomes. Designed for compatibility with 3.5mm SLPS systems, it ensures accurate bone fixation and enhanced patient recovery in orthopedic trauma procedures. Essential equipment for modern operating theaters requiring reliable, sterile surgical instrumentation.","technical_specifications":{"drill_bits":"2.5mm, 2.8mm, 3.5mm","includes":"Torque limiter, depth gauge, universal drill guides","compatibility":"3.5mm SLPS system"},"brand":"KET","parent_brand":"","description_shadow":"","division_shadow_original":"","shadow_product_id":"","shadow_source_files":[],"shadow_source_pages":[],"shadow_sku_count":0,"source_of_truth_fields":{"slug":"live","images":"live","status":"live","seo_meta_title":"live","seo_meta_description":"live","brochure_url":"live","pack_size":"live","size_variables":"live","description_live":"live","technical_specifications":"live","brand":"none","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"high","review_required":false,"match_method":"none","match_score":0,"catalog_created_at":"2026-03-27T16:50:59.528988+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Complete surgical instrument set for 3.5mm locking plate fixation procedures","proposed_clinical_display_title":"KET 3.5mm Locking Plate System Instrument Set","proposed_clinical_subtitle":"Complete surgical instrument set for 3.5mm locking plate fixation procedures","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T04:19:49.183131+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"Internal evidence clearly describes a comprehensive surgical instrument set for 3.5mm locking plate procedures with specific drill bits (2.5mm, 2.8mm, 3.5mm), torque limiter, depth gauge, and universal drill guides. External evidence from tier1_manufacturer sources confirms this is Meril's KET brand system (KET 3.5mm Locking Plate System, part MT-INSLPS002). The product is an instrument set, not an implant. Brand 'KET' was missing from current title. Classification is consistent across sources: trauma fixation instrument set for small fragment applications. Material specification (surgical grade stainless steel) is standard for such instruments. Recommended action is rename to include the verified KET brand designation for proper clinical identification and catalog organization.","proposed_recommended_action":"rename","proposed_semantic_anatomy_scope":["Small Fragment Bone","Extremities"],"proposed_semantic_brand_system":"KET","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.92,"proposed_semantic_family_group":"KET 3.5mm Locking Plate System","proposed_semantic_implant_class":"Trauma Fixation Instruments","proposed_semantic_material_default":"Stainless Steel (Surgical Grade)","proposed_semantic_parent_brand":"Meril Life Sciences","proposed_semantic_procedure_scope":["Trauma Fixation","Fracture Fixation","Orthopedic Reconstruction"],"proposed_semantic_review_required":false,"proposed_semantic_system_type":"Locking Plate System","proposed_semantic_use_case_tags":["small fragment fixation","locking compression plate","trauma surgery","bone drilling","screw insertion"],"proposed_web_verification_status":"externally_enriched","semantic_anatomy_scope":["Small Fragment Bone","Extremities"],"semantic_brand_system":"KET","semantic_coating_default":null,"semantic_confidence":0.92,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T09:39:03.449206+00:00","semantic_implant_class":"Trauma Fixation Instruments","semantic_material_default":"Stainless Steel (Surgical Grade)","semantic_parent_brand":"Meril Life Sciences","semantic_review_required":false,"semantic_rule_hits":["WEB_FALLBACK_EXTERNALLY_ENRICHED"],"semantic_system_type":"Locking Plate System"}}]
