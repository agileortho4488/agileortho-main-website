ne","parent_brand":"none","description_shadow":"none","shadow_source_files":"none"},"enriched_from_shadow":false,"mapping_confidence":"medium","review_required":false,"match_method":"fuzzy_token","match_score":0.444,"catalog_created_at":"2026-03-27T16:51:00.137952+00:00","clinical_reclassified_at":"2026-03-27 18:21:25.378000","clinical_subtitle":"Self-Tapping Titanium Alloy Screw with T8 Drive for Multi-Angle Locking Plates","proposed_clinical_display_title":"Variabilis 2.4mm Locking Screw, 22mm Length","proposed_clinical_subtitle":"Self-Tapping Titanium Alloy Screw with T8 Drive for Multi-Angle Locking Plates","proposed_conflict_detected":false,"proposed_enriched_at":"2026-03-28T07:25:58.917563+00:00","proposed_entity_type":"instrument","proposed_reasoning_summary":"This is a specific component (individual locking screw) within the Variabilis 2.4mm Locking Screws family. The 2.4mm diameter indicates small fragment trauma applications, typically for hand, wrist, foot, ankle, or pediatric fractures. Internal evidence is consistent: Trauma division, Locking Screws category, specific dimensions (2.4mm × 22mm), material (Ti-6Al-7Nb), and drive type (T8 self-tapping). The product is a consumable implant component, not a standalone product family. However, brand is missing (manufacturer shown as Meril, but brand field empty), and no external verification was possible. Confidence set to 0.85 due to consistent internal evidence, but review required to confirm: (1) whether 'Variabilis' is indeed the brand/system name, (2) anatomical scope accuracy for 2.4mm screws, and (3) whether this individual screw length should have its own catalog page or be merged into a parent Variabilis 2.4mm family page with length variants.","proposed_recommended_action":"send_to_review","proposed_semantic_anatomy_scope":["Upper Extremity","Lower Extremity","Small Bone"],"proposed_semantic_brand_system":"Variabilis Multi-Angle Plates","proposed_semantic_coating_default":null,"proposed_semantic_confidence":0.85,"proposed_semantic_family_group":"Variabilis 2.4mm Locking Screws","proposed_semantic_implant_class":"Locking Screw","proposed_semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","proposed_semantic_parent_brand":"Variabilis","proposed_semantic_procedure_scope":["Fracture Fixation","Osteotomy","Arthrodesis"],"proposed_semantic_review_required":true,"proposed_semantic_system_type":"Multi-Angle Locking Plate System","proposed_semantic_use_case_tags":["2.4mm diameter","22mm length","Self-tapping","T8 drive","Multi-angle locking","Small fragment fixation"],"proposed_web_verification_status":"review_required_ambiguity","semantic_anatomy_scope":["Upper Extremity","Lower Extremity","Small Bone"],"semantic_brand_system":"Variabilis Multi-Angle Plates","semantic_coating_default":null,"semantic_confidence":0.85,"semantic_conflict_codes":[],"semantic_enriched_at":"2026-03-28T10:53:49.064326+00:00","semantic_implant_class":"Locking Screw","semantic_material_default":"Titanium Alloy (Ti-6Al-7Nb)","semantic_parent_brand":"Variabilis","semantic_review_required":false,"semantic_rule_hits":["AUTO_LANE1_SAFE_REVIEW_REQUIRED_AMBIGUITY"],"semantic_system_type":"Multi-Angle Locking Plate System","clinical_indications":["Fractures","Bone Tumors","Deformities"],"materials_canonical":"Titanium Alloy","features_list":["High fatigue strength","Proper Fixation","Negligible Soft Tissue Damage"],"brochure_intelligence_updated":true}}]
