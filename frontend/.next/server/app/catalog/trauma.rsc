115:["$","div",null,{"className":"mt-24 pt-12 border-t border-white/10 max-w-4xl mx-auto text-center","children":[["$","h2",null,{"className":"text-2xl font-bold font-heading text-white mb-6","children":"Advanced Trauma Implants & Fracture Management Solutions"}],["$","div",null,{"className":"space-y-4 text-muted-foreground leading-relaxed text-sm","children":[["$","p","0",{"children":"Agile Healthcare is the premier authorized distributor for Meril Life Sciences' comprehensive trauma portfolio across Telangana. Our trauma division provides state-of-the-art orthopedic implants designed for complex fracture management, non-unions, and osteotomies."}],["$","p","1",{"children":"From anatomically contoured locking plates and intramedullary nailing systems to external fixators, every product in our catalog adheres to the highest global quality standards including CE and CDSCO approvals. Our implants are manufactured using medical-grade Titanium and Stainless Steel, ensuring optimal biocompatibility and mechanical strength."}],["$","p","2",{"children":"We understand that trauma is time-critical. Our 24/7 OT Command Center ensures that hospitals across all 33 districts of Telangana receive the exact specifications of plates, screws, and instrumentation kits within hours of a surgical requirement."}]]}]]}]
