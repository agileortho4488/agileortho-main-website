52:["$","div",null,{"className":"mt-24 pt-12 border-t border-white/10 max-w-4xl mx-auto text-center","children":[["$","h2",null,{"className":"text-2xl font-bold font-heading text-white mb-6","children":"Cardiovascular Interventions & Stent Systems"}],["$","div",null,{"className":"space-y-4 text-muted-foreground leading-relaxed text-sm","children":[["$","p","0",{"children":"Agile Healthcare's cardiovascular division supplies life-saving structural heart devices, including the revolutionary Myval Transcatheter Heart Valve (THV) and a wide array of drug-eluting stents (DES), balloon catheters, and guide wires."}],["$","p","1",{"children":"Meril's cardiovascular portfolio is globally recognized for clinical excellence. As an authorized master distributor, we ensure that cath labs and cardiac centers across Telangana are equipped with the latest innovations in interventional cardiology and peripheral vascular treatments."}],["$","p","2",{"children":"Our cold-chain logistics and compliance frameworks guarantee that every cardiovascular product is delivered maintaining strict temperature and environmental controls, fully certified by the CDSCO."}]]}]]}]
