90:["$","div",null,{"className":"mt-24 pt-12 border-t border-white/10 max-w-4xl mx-auto text-center","children":[["$","h2",null,{"className":"text-2xl font-bold font-heading text-white mb-6","children":"High-Performance Arthroplasty & Joint Care"}],["$","div",null,{"className":"space-y-4 text-muted-foreground leading-relaxed text-sm","children":[["$","p","0",{"children":"Our Joint Replacement division features Meril's cutting-edge arthroplasty solutions, including Total Knee Arthroplasty (TKA) and Total Hip Arthroplasty (THA) systems. Engineered for high flexion, maximum survivorship, and bone preservation, these implants represent the pinnacle of modern joint reconstruction."}],["$","p","1",{"children":"We supply the Destiknee system, Opulent Bionics, and advanced revision arthroplasty components. Our dedicated clinical support team assists surgeons with preoperative templating and anatomical sizing wizards to ensure optimal patient outcomes."}],["$","p","2",{"children":"By maintaining a robust supply chain from our Hyderabad headquarters, Agile Healthcare guarantees the immediate availability of varying sizes and modular components for scheduled and emergency joint replacement procedures."}]]}]]}]
